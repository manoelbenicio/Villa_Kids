---
/**
 * @file TrustBadge.astro
 * @description DS v3 KPI/trust badge. Uses global `glass-light`, `kpi`, and
 *              `badge-*` classes while preserving count-up data attributes.
 */

export interface Props {
  /** Final integer value to count up to. */
  value: number;
  /** Optional suffix appended to the number (e.g. "+", "%"). */
  suffix?: string;
  /** Optional prefix prepended to the number (e.g. "R$"). */
  prefix?: string;
  /** Description label below the number. */
  label: string;
  /** Stagger delay in ms for grid entrance. */
  delay?: number;
  /** Animation duration in ms (default 1600). */
  duration?: number;
  /** DS v3 badge color. */
  variant?: 'purple' | 'green' | 'gold' | 'cyan' | 'magenta';
  /** Optional inline badge caption shown above the KPI. */
  badge?: string;
  /** Optional emoji/icon rendered inline before the badge caption. */
  icon?: string;
}

const {
  value,
  suffix = '',
  prefix = '',
  label,
  delay = 0,
  duration = 1600,
  variant,
  badge,
  icon,
} = Astro.props;
const variants = ['purple', 'green', 'gold', 'cyan', 'magenta'] as const;
const badgeVariant = variant ?? variants[Math.abs(Math.floor(delay / 80)) % variants.length];
---

<div class="trust-badge glass-light kpi reveal" data-animate="fade-scale" data-reveal-delay={delay}>
  {(badge || prefix || icon) && (
    <span class:list={['badge', `badge-${badgeVariant}`]}>
      {icon && <span class="badge-icon" aria-hidden="true">{icon}</span>}
      {badge ?? prefix}
    </span>
  )}
  <span
    class="kpi-val trust-number"
    data-countup={value}
    data-countup-suffix={suffix}
    data-countup-duration={duration}
    aria-label={`${prefix}${value}${suffix} ${label}`}
  >
    {prefix}0{suffix}
  </span>
  <span class="kpi-lbl trust-label">{label}</span>
</div>

<style>
  .glass-light {
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(155, 89, 182, 0.08);
    border-radius: var(--r-xl, 24px);
    transition: all var(--t-normal, 300ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .glass-light:hover {
    background: rgba(255, 255, 255, 0.9);
    box-shadow: var(--shadow-lg, 0 12px 32px rgba(0, 0, 0, 0.12));
    transform: translateY(-3px);
  }

  .kpi {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-2, 0.5rem);
    text-align: center;
    padding: var(--s-6, 1.5rem);
  }

  .kpi-val {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1;
    color: var(--vp-purple, #9b59b6);
  }

  .kpi-lbl {
    font-family: var(--font-body, var(--font-sans));
    font-size: 12px;
    font-weight: 700;
    color: var(--vp-gray-500, var(--color-neutral-600));
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    border-radius: var(--r-full, var(--radius-full));
    font-family: var(--font-body, var(--font-sans));
    font-size: 12px;
    font-weight: 700;
  }

  .badge-icon {
    line-height: 1;
  }

  .badge-purple { background: rgba(155, 89, 182, 0.1); color: var(--vp-purple, #9b59b6); }
  .badge-green { background: rgba(126, 211, 33, 0.1); color: var(--vp-green-deep, #5ba018); }
  .badge-gold { background: rgba(255, 215, 0, 0.15); color: var(--vp-gold-deep, #daa520); }
  .badge-cyan { background: rgba(80, 227, 194, 0.1); color: var(--vp-cyan-deep, #2db89b); }
  .badge-magenta { background: rgba(255, 0, 128, 0.08); color: var(--vp-magenta, #ff0080); }

  @media (prefers-reduced-motion: reduce) {
    .glass-light { transition: none; }
    .glass-light:hover { transform: none; }
  }
</style>
