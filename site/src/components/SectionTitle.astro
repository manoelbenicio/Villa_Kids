---
/**
 * @file SectionTitle.astro
 * @description Standardized section heading with optional decorative tag pill,
 *              animated gold underline, and an optional subtitle. Drives a
 *              consistent rhythm across all institutional sections.
 *
 *              Props
 *              - tag        Decorative small-caps pill (e.g. "PROPOSTA")
 *              - title      Required h2 string
 *              - subtitle   Optional descriptor paragraph
 *              - alignment  left | center | right (default: center)
 *              - decorated  Show underline accent (default: true)
 *
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */

export interface Props {
  tag?: string;
  title: string;
  subtitle?: string;
  alignment?: 'left' | 'center' | 'right';
  decorated?: boolean;
  /** Override the heading level (default 2). */
  level?: 1 | 2 | 3;
}

const {
  tag,
  title,
  subtitle,
  alignment = 'center',
  decorated = true,
  level = 2,
} = Astro.props;

const Heading = `h${level}` as const;
---

<header class:list={['section-title', `align-${alignment}`]}>
  {tag && (
    <span class="section-tag reveal" data-reveal-delay="0">
      <span class="section-tag-dot" aria-hidden="true"></span>
      {tag}
    </span>
  )}
  <Heading class="section-heading reveal" data-reveal-delay="80">{title}</Heading>
  {decorated && <span class="section-divider reveal" data-reveal-delay="160" aria-hidden="true"></span>}
  {subtitle && <p class="section-subtitle reveal" data-reveal-delay="200">{subtitle}</p>}
</header>

<style>
  .section-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 64rem;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .align-left {
    text-align: left;
    align-items: flex-start;
    margin-inline: 0;
  }

  .align-center {
    text-align: center;
    align-items: center;
  }

  .align-right {
    text-align: right;
    align-items: flex-end;
    margin-inline: 0 0;
    margin-left: auto;
  }

  /* --- Tag pill --- */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-700);
    background-color: var(--color-accent-50);
    border: 1px solid var(--color-accent-200);
    border-radius: var(--radius-full);
  }

  .section-tag-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--color-accent-500);
    box-shadow: 0 0 0 3px rgb(212 169 16 / 0.18);
  }

  /* --- Heading --- */
  .section-heading {
    font-family: var(--font-display);
    color: var(--color-primary-800);
    margin: 0;
    text-wrap: balance;
  }

  /* --- Decorative divider --- */
  .section-divider {
    display: block;
    width: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--color-accent-400) 0%,
      var(--color-accent-600) 100%
    );
    border-radius: var(--radius-full);
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .section-divider.visible {
    width: 4rem;
  }

  .align-left .section-divider {
    margin-left: 0;
  }
  .align-right .section-divider {
    margin-right: 0;
  }

  /* --- Subtitle --- */
  .section-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    line-height: 1.6;
    max-width: 48rem;
    margin: 0;
    text-wrap: pretty;
  }

  @media (max-width: 640px) {
    .section-subtitle {
      font-size: var(--text-base);
    }
  }
</style>
