---
/**
 * @file Footer.astro
 * @description DS v3 dark premium 4-column footer.
 */
import { schoolInfo, whatsappLink } from '../data/school-info.ts';
import { footerQuickLinks, footerLegalLinks } from '../data/navigation.ts';

const currentYear = new Date().getFullYear();
---

<footer class="footer site-footer">
  <div class="footer-glow" aria-hidden="true"></div>

  <div class="container footer-grid">
    <div class="footer-brand">
      <a class="footer-logo nav-logo" href="/" aria-label={`${schoolInfo.name} - voltar à página inicial`}>
        <span class="footer-logo-mark" aria-hidden="true">★</span>
        <span>Villa Prime</span>
      </a>
      <p class="footer-desc">{schoolInfo.shortDescription}</p>
      <p class="footer-tagline">{schoolInfo.tagline}.</p>
    </div>

    <nav aria-label="Links rápidos">
      <h2 class="footer-title">Navegação</h2>
      <ul class="footer-links">
        {footerQuickLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div>
      <h2 class="footer-title">Contato</h2>
      <ul class="footer-links footer-contact-links">
        <li><span>📍 {schoolInfo.address.fullStreet}</span></li>
        <li><a href={`tel:${schoolInfo.phoneRaw}`}>📞 {schoolInfo.phone}</a></li>
        <li><a href={`mailto:${schoolInfo.email}`}>✉️ {schoolInfo.email}</a></li>
        <li><span>🕐 {schoolInfo.hours}</span></li>
      </ul>
    </div>

    <div>
      <h2 class="footer-title">Acompanhe</h2>
      <ul class="footer-links">
        {schoolInfo.social.instagram && (
          <li><a href={schoolInfo.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></li>
        )}
        {schoolInfo.social.facebook && (
          <li><a href={schoolInfo.social.facebook} target="_blank" rel="noopener noreferrer">Facebook</a></li>
        )}
      </ul>
      <a href={whatsappLink()} class="footer-whatsapp" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        <span>WhatsApp</span>
      </a>
    </div>
  </div>

  <div class="footer-bottom container">
    <span>© {currentYear} {schoolInfo.legalName}. Todos os direitos reservados.</span>
    <ul class="footer-legal">
      {footerLegalLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    background: var(--vp-gray-900, #111827);
    padding: var(--s-16, 4rem) 0 var(--s-8, 2rem);
    margin-top: auto;
  }

  .footer-glow {
    position: absolute;
    top: -30%;
    right: -15%;
    width: 60%;
    height: 90%;
    background: radial-gradient(ellipse at center, rgba(155, 89, 182, 0.28) 0%, transparent 62%);
    pointer-events: none;
    z-index: -1;
  }

  .footer::before {
    content: '';
    position: absolute;
    left: -12%;
    bottom: -30%;
    width: 44%;
    height: 70%;
    background: radial-gradient(ellipse at center, rgba(80, 227, 194, 0.14) 0%, transparent 64%);
    pointer-events: none;
    z-index: -1;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--s-12, 3rem);
    margin-bottom: var(--s-12, 3rem);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3, 0.75rem);
    color: #fff;
    text-decoration: none;
  }

  .footer-logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    color: #fff;
    background: var(--grad-magic, linear-gradient(135deg, #ff0080 0%, #9b59b6 50%, #50e3c2 100%));
    border-radius: 50%;
    box-shadow: 0 10px 28px rgba(155, 89, 182, 0.28);
  }

  .footer-logo span:last-child {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: #fff;
  }

  .footer-desc {
    max-width: 320px;
    margin: var(--s-4, 1rem) 0 0;
    color: var(--vp-gray-400, #9ca3af);
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
    line-height: 1.7;
  }

  .footer-tagline {
    margin: var(--s-3, 0.75rem) 0 0;
    color: var(--vp-cyan, #50e3c2);
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
  }

  .footer-title {
    margin: 0 0 var(--s-4, 1rem);
    color: #fff;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
  }

  .footer-links,
  .footer-legal {
    display: flex;
    flex-direction: column;
    gap: var(--s-3, 0.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links a,
  .footer-links span {
    color: var(--vp-gray-400, #9ca3af);
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
    line-height: 1.55;
    text-decoration: none;
    transition: color var(--t-fast, 200ms) ease;
  }

  .footer-links a:hover {
    color: var(--vp-cyan, #50e3c2);
  }

  .footer-contact-links li {
    max-width: 28ch;
  }

  .footer-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2, 0.5rem);
    margin-top: var(--s-5, 1.25rem);
    padding: 10px 18px;
    color: #fff;
    background: linear-gradient(135deg, #25d366 0%, var(--vp-green, #7ed321) 100%);
    border-radius: var(--r-full, 9999px);
    font-family: var(--font-body, var(--font-sans));
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(37, 211, 102, 0.22);
    transition: transform var(--t-fast, 200ms) var(--ease-spring, cubic-bezier(0.34, 1.56, 0.64, 1));
  }

  .footer-whatsapp:hover {
    color: #fff;
    transform: translateY(-2px);
  }

  .footer-whatsapp svg {
    width: 16px;
    height: 16px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-4, 1rem);
    padding-top: var(--s-8, 2rem);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--vp-gray-500, #6b7280);
    font-family: var(--font-body, var(--font-sans));
    font-size: 13px;
  }

  .footer-legal {
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--s-4, 1rem);
  }

  .footer-legal a {
    color: var(--vp-gray-500, #6b7280);
    font-family: var(--font-body, var(--font-sans));
    font-size: 13px;
  }

  .footer-legal a:hover {
    color: var(--vp-cyan, #50e3c2);
  }

  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; text-align: center; }
    .footer-legal { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-links a,
    .footer-whatsapp,
    .footer-legal a { transition: none; }
    .footer-whatsapp:hover { transform: none; }
  }
</style>
