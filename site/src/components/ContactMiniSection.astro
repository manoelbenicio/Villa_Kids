---
/**
 * @file ContactMiniSection.astro
 * @description Compact contact strip placed at the end of every internal
 *              page (per ARCHITECTURE-BLUEPRINT Section 3.2). Provides a
 *              quick path to WhatsApp, phone, and email without forcing
 *              the user back to the home or to the contact page.
 *
 * @author GEMINI-UX
 * @phase 4
 * @created 2026-05-17T21:34:00Z
 */
import { schoolInfo, whatsappLink } from '../data/school-info.ts';
import CTAButton from './CTAButton.astro';

export interface Props {
  /** Optional headline override. */
  title?: string;
  /** Optional subtitle override. */
  subtitle?: string;
}

const {
  title = 'Conversemos',
  subtitle = 'Estamos aqui para responder suas dúvidas e mostrar a escola pessoalmente.',
} = Astro.props;
---

<section class="contact-mini">
  <div class="container contact-mini-inner">
    <div class="contact-mini-text reveal">
      <span class="contact-mini-eyebrow">
        <span class="contact-mini-eyebrow-dot" aria-hidden="true"></span>
        Fale conosco
      </span>
      <h2 class="contact-mini-title">{title}</h2>
      <p class="contact-mini-subtitle">{subtitle}</p>
    </div>

    <div class="contact-mini-meta reveal" data-reveal-delay="120">
      <a href={`tel:${schoolInfo.phoneRaw}`} class="contact-mini-meta-item">
        <span class="contact-mini-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        </span>
        <span class="contact-mini-meta-text">
          <span class="contact-mini-meta-label">Telefone</span>
          <span class="contact-mini-meta-value">{schoolInfo.phone}</span>
        </span>
      </a>

      <a href={`mailto:${schoolInfo.email}`} class="contact-mini-meta-item">
        <span class="contact-mini-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
        </span>
        <span class="contact-mini-meta-text">
          <span class="contact-mini-meta-label">E-mail</span>
          <span class="contact-mini-meta-value">{schoolInfo.email}</span>
        </span>
      </a>
    </div>

    <div class="contact-mini-cta reveal" data-reveal-delay="200">
      <CTAButton
        text="Conversar pelo WhatsApp"
        href={whatsappLink()}
        variant="whatsapp"
        size="md"
      />
      <CTAButton
        text="Página de contato"
        href="/contato/"
        variant="secondary"
        size="md"
      />
    </div>
  </div>
</section>

<style>
  .contact-mini {
    background-color: var(--color-surface);
    border-top: 1px solid var(--vp-gray-200, #e5e7eb);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .contact-mini-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    align-items: center;
  }

  @media (max-width: 1024px) {
    .contact-mini-inner {
      grid-template-columns: 1fr;
      text-align: left;
    }
  }

  .contact-mini-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-mini-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.35rem 0.85rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-700, #8a6408);
    background-color: rgba(255, 215, 0, 0.12);
    border: 1px solid rgba(255, 215, 0, 0.24);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .contact-mini-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--color-accent-700, #8a6408);
  }

  .contact-mini-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2vw + 0.8rem, 2.25rem);
    line-height: 1.15;
    color: var(--vp-gray-900, #111827);
    margin: 0;
    letter-spacing: -0.015em;
  }

  .contact-mini-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--vp-gray-600, #4b5563);
    margin: 0;
    max-width: 30rem;
  }

  /* --- Meta items (phone + email) --- */
  .contact-mini-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-mini-meta-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--vp-gray-900, #111827);
    text-decoration: none;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .contact-mini-meta-item:hover {
    transform: translateX(2px);
    color: var(--vp-purple, #9b59b6);
  }

  .contact-mini-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-accent-700, #8a6408);
    background: linear-gradient(
      135deg,
      rgba(255, 215, 0, 0.12) 0%,
      rgba(255, 215, 0, 0.16) 100%
    );
    border: 1px solid rgba(255, 215, 0, 0.24);
    border-radius: var(--radius-md);
  }

  .contact-mini-icon svg {
    width: 18px;
    height: 18px;
  }

  .contact-mini-meta-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .contact-mini-meta-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--vp-gray-500, #6b7280);
  }

  .contact-mini-meta-value {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
  }

  /* --- CTA buttons --- */
  .contact-mini-cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: stretch;
  }

  @media (max-width: 1024px) {
    .contact-mini-cta {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-mini-meta-item { transition: none; }
    .contact-mini-meta-item:hover { transform: none; }
  }
</style>
