---
/**
 * @file FeatureCard.astro
 * @description Pillar/feature card with 64px accent icon, title (h3),
 *              description paragraph, and an optional inline link.
 *              Hover effect: lift + accent border + shadow upgrade.
 *
 *              `icon` is raw inline SVG (24x24 viewBox, currentColor).
 *              The wrapping figure sets the displayed size and color.
 *
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */

export interface Props {
  title: string;
  description: string;
  /** Inline SVG markup (currentColor recommended). */
  icon: string;
  link?: string;
  /** Optional numeric stagger delay in ms (used for grid entrance). */
  delay?: number;
}

const { title, description, icon, link, delay = 0 } = Astro.props;
---

<article class="feature-card reveal" data-reveal-delay={delay} tabindex={link ? -1 : undefined}>
  <figure class="feature-icon" set:html={icon} aria-hidden="true" />
  <h3 class="feature-title">{title}</h3>
  <p class="feature-description">{description}</p>
  {link && (
    <a class="feature-link" href={link}>
      <span>Saiba mais</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
  )}
</article>

<style>
  .feature-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    transition:
      transform 300ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 300ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 300ms cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    isolation: isolate;
  }

  /* Subtle gradient halo on hover */
  .feature-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top right,
      rgb(246 201 31 / 0.08) 0%,
      transparent 60%
    );
    opacity: 0;
    transition: opacity 300ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: -1;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-accent-200);
  }

  .feature-card:hover::before {
    opacity: 1;
  }

  /* --- Icon --- */
  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin: 0 0 var(--space-2);
    color: var(--color-accent-600);
    background: linear-gradient(
      135deg,
      var(--color-accent-50) 0%,
      var(--color-accent-100) 100%
    );
    border-radius: var(--radius-lg);
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.06) rotate(-3deg);
  }

  .feature-icon :global(svg) {
    width: 32px;
    height: 32px;
  }

  /* --- Text --- */
  .feature-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-primary-800);
    margin: 0;
    line-height: 1.2;
  }

  .feature-description {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-neutral-600);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  /* --- Inline link --- */
  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary-600);
    transition: gap 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .feature-link svg {
    width: 1em;
    height: 1em;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .feature-link:hover {
    color: var(--color-primary-800);
    gap: 0.65rem;
  }

  .feature-link:hover svg {
    transform: translateX(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card,
    .feature-icon,
    .feature-link,
    .feature-link svg {
      transition: none;
    }
    .feature-card:hover {
      transform: none;
    }
    .feature-card:hover .feature-icon {
      transform: none;
    }
  }
</style>
