---
/**
 * @file WhatsAppButton.astro
 * @description Floating fixed bottom-right WhatsApp call. White glyph on
 *              official #25D366 background. Subtle infinite pulse, hover
 *              scale 1.1, and a tooltip that appears on hover.
 *
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */
import { schoolInfo, whatsappLink } from '../data/school-info.ts';

export interface Props {
  /** Override the default pre-filled message. */
  message?: string;
  /** Override the tooltip text. */
  tooltip?: string;
}

const { message, tooltip = 'Fale conosco no WhatsApp' } = Astro.props;
const href = whatsappLink(message);
---

<a
  class="whatsapp-fab"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Conversar com ${schoolInfo.name} pelo WhatsApp`}
>
  <span class="whatsapp-tooltip" aria-hidden="true">{tooltip}</span>
  <span class="whatsapp-pulse" aria-hidden="true"></span>
  <svg
    class="whatsapp-glyph"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
  </svg>
</a>

<style>
  .whatsapp-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 60px;
    height: 60px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background-color: #25d366;
    border-radius: var(--radius-full);
    box-shadow:
      0 12px 24px -8px rgb(37 211 102 / 0.5),
      var(--shadow-xl);
    z-index: var(--z-tooltip);
    transition:
      transform 250ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 250ms cubic-bezier(0.4, 0, 0.2, 1),
      background-color 250ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .whatsapp-fab:hover {
    transform: scale(1.1);
    background-color: #1ebe5a;
    box-shadow:
      0 16px 32px -10px rgb(37 211 102 / 0.6),
      0 0 0 6px rgb(37 211 102 / 0.18);
    color: #fff;
  }

  .whatsapp-fab:focus-visible {
    outline: 3px solid var(--color-accent-500);
    outline-offset: 4px;
  }

  /* --- Pulse halo --- */
  .whatsapp-pulse {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-full);
    background-color: #25d366;
    opacity: 0.6;
    animation: whatsappPulse 2.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    z-index: -1;
  }

  @keyframes whatsappPulse {
    0% {
      transform: scale(1);
      opacity: 0.55;
    }
    70% {
      transform: scale(1.5);
      opacity: 0;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  /* --- Glyph --- */
  .whatsapp-glyph {
    width: 30px;
    height: 30px;
    position: relative;
    z-index: 1;
  }

  /* --- Tooltip --- */
  .whatsapp-tooltip {
    position: absolute;
    right: calc(100% + 0.75rem);
    top: 50%;
    transform: translateY(-50%) translateX(8px);
    padding: 0.55rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary-900);
    background-color: #fff;
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 200ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .whatsapp-tooltip::after {
    content: '';
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: #fff;
  }

  .whatsapp-fab:hover .whatsapp-tooltip,
  .whatsapp-fab:focus-visible .whatsapp-tooltip {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  @media (max-width: 640px) {
    .whatsapp-fab {
      width: 54px;
      height: 54px;
      bottom: 1rem;
      right: 1rem;
    }
    .whatsapp-glyph {
      width: 26px;
      height: 26px;
    }
    .whatsapp-tooltip {
      display: none; /* Tooltip is redundant on touch */
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-pulse { animation: none; opacity: 0; }
    .whatsapp-fab,
    .whatsapp-tooltip { transition: none; }
    .whatsapp-fab:hover { transform: none; }
  }
</style>
