---
/**
 * @file Hero.astro
 * @description DS v3 immersive hero with canvas particles, animated blobs,
 *              glass chip, accent word, premium CTAs, and KPI counters.
 */
import CTAButton from './CTAButton.astro';
import { schoolInfo, whatsappLink } from '../data/school-info.ts';

export interface HeroMetric {
  value: number;
  suffix?: string;
  label: string;
}

export interface Props {
  /** Optional chip above the H1. */
  eyebrow?: string;
  /** Required H1. */
  title: string;
  /** Optional word/phrase in the H1 to highlight. Defaults to a smart match. */
  accentText?: string;
  /** Required descriptor paragraph below H1. */
  subtitle: string;
  /** Primary CTA - defaults to "Agende uma Visita" (WhatsApp). */
  primaryCta?: { text: string; href: string; whatsapp?: boolean };
  /** Secondary CTA - defaults to "Conheça a Escola" (outline). */
  secondaryCta?: { text: string; href: string };
  /** Kept for API compatibility; rendered as a very subtle texture layer. */
  backgroundImage?: string;
  /** Disable canvas/parallax motion. Default false. */
  disableParallax?: boolean;
  /** Optional KPI row. Set [] to hide. */
  metrics?: HeroMetric[];
}

const {
  eyebrow = 'Referência em Educação Infantil Premium',
  title,
  accentText,
  subtitle,
  primaryCta = {
    text: 'Agende uma Visita',
    href: whatsappLink(),
    whatsapp: true,
  },
  secondaryCta = {
    text: 'Conheça a Escola',
    href: '#sobre',
  },
  backgroundImage,
  disableParallax = false,
  metrics = [
    { value: 6, suffix: ' anos', label: 'Educação Infantil' },
    { value: 12, suffix: 'h', label: 'Rotina Integral' },
    { value: 100, suffix: '%', label: 'Ambiente Monitorado' },
    { value: 5, label: 'Etapas do Desenvolvimento' },
  ],
} = Astro.props;

const wordsToAccent = [accentText, 'transforma', 'estrela', 'Prime', 'criança'].filter(Boolean) as string[];
const accent = wordsToAccent.find((word) => title.includes(word));
const titleParts = accent ? title.split(accent) : [title];
const bgStyle = backgroundImage ? `background-image: url('${backgroundImage}');` : '';
---

<section class="hero" data-disable-parallax={String(disableParallax)}>
  <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-image" style={bgStyle} aria-hidden="true"></div>
  <div class="hero-blob" aria-hidden="true"></div>
  <div class="hero-blob" aria-hidden="true"></div>
  <div class="hero-blob" aria-hidden="true"></div>

  <div class="hero-inner container">
    {eyebrow && <div class="hero-chip">⭐ {eyebrow}</div>}

    <h1>
      {accent ? (
        <>
          {titleParts[0]}<span class="accent">{accent}</span>{titleParts.slice(1).join(accent)}
        </>
      ) : title}
    </h1>

    <p class="hero-sub">{subtitle}</p>

    <div class="hero-btns">
      <CTAButton
        text={primaryCta.text}
        href={primaryCta.href}
        variant={primaryCta.whatsapp ? 'whatsapp' : 'primary'}
        size="lg"
        external={primaryCta.whatsapp}
      />
      <CTAButton
        text={secondaryCta.text}
        href={secondaryCta.href}
        variant="outline"
        size="lg"
      />
    </div>

    <slot name="meta" />

    {metrics.length > 0 && (
      <div class="hero-metrics">
        {metrics.map((metric) => (
          <div class="hero-metric">
            <div
              class="hero-metric-val"
              data-countup={metric.value}
              data-countup-suffix={metric.suffix ?? ''}
            >
              0{metric.suffix ?? ''}
            </div>
            <div class="hero-metric-lbl">{metric.label}</div>
          </div>
        ))}
      </div>
    )}

    <a class="hero-scroll-cue" href="#sobre" aria-label="Rolar para a próxima seção">
      <span>Role para descobrir</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 5v14"/><path d="m19 12-7 7-7-7"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    background: var(--grad-hero, linear-gradient(135deg, #6c3483 0%, #9b59b6 40%, #bb8fce 100%));
  }

  .hero-canvas,
  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-image {
    background-size: cover;
    background-position: center;
    opacity: 0.1;
    mix-blend-mode: screen;
    filter: saturate(1.2);
    pointer-events: none;
  }

  .hero-blob {
    position: absolute;
    width: min(600px, 70vw);
    height: min(600px, 70vw);
    opacity: 0.16;
    background: var(--grad-aurora, linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%));
    filter: blur(80px);
    animation: morphBlob 15s ease-in-out infinite, float 8s ease-in-out infinite;
    z-index: 0;
  }

  .hero-blob:nth-of-type(2) {
    right: -200px;
    top: -100px;
    animation-delay: -5s;
    background: var(--grad-sunset, linear-gradient(135deg, #fa709a 0%, #fee140 100%));
  }

  .hero-blob:nth-of-type(3) {
    left: -150px;
    bottom: -200px;
    animation-delay: -10s;
    background: var(--grad-ocean, linear-gradient(135deg, #50e3c2 0%, #3b82f6 100%));
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 960px;
    padding-block: var(--s-24, 6rem) var(--s-16, 4rem);
    text-align: center;
  }

  .hero-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2, 0.5rem);
    margin-bottom: var(--s-8, 2rem);
    padding: 8px 20px;
    color: rgba(255, 255, 255, 0.92);
    font-family: var(--font-body, var(--font-sans));
    font-size: 13px;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--r-full, var(--radius-full));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    animation: fadeInDown var(--t-emphasis, 800ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) 0.2s both;
  }

  .hero h1 {
    margin: 0 0 var(--s-6, 1.5rem);
    font-family: var(--font-display);
    font-size: clamp(42px, 7vw, 80px);
    font-weight: 700;
    line-height: 1.05;
    color: #fff;
    letter-spacing: -0.03em;
    text-wrap: balance;
    animation: fadeInUp var(--t-dramatic, 1200ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) 0.4s both;
  }

  .hero h1 .accent {
    background: linear-gradient(135deg, var(--vp-yellow, #f8e71c) 0%, var(--vp-orange, #f5a623) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 200%;
    animation: gradientShift 4s ease infinite;
  }

  .hero-sub {
    max-width: 680px;
    margin: 0 auto var(--s-10, 2.5rem);
    color: rgba(255, 255, 255, 0.86);
    font-family: var(--font-body, var(--font-sans));
    font-size: clamp(16px, 2.2vw, 22px);
    line-height: 1.7;
    text-wrap: pretty;
    animation: fadeInUp var(--t-dramatic, 1200ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) 0.6s both;
  }

  .hero-btns {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--s-4, 1rem);
    animation: fadeInUp var(--t-dramatic, 1200ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) 0.8s both;
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-6, 1.5rem);
    margin-top: var(--s-16, 4rem);
    padding-top: var(--s-8, 2rem);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    animation: fadeInUp var(--t-dramatic, 1200ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)) 1s both;
  }

  .hero-metric {
    text-align: center;
  }

  .hero-metric-val {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1;
    color: #fff;
  }

  .hero-metric-lbl {
    margin-top: var(--s-1, 0.25rem);
    color: rgba(255, 255, 255, 0.66);
    font-family: var(--font-body, var(--font-sans));
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-scroll-cue {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-1, 0.25rem);
    margin-top: var(--s-8, 2rem);
    color: rgba(255, 255, 255, 0.68);
    font-family: var(--font-body, var(--font-sans));
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-scroll-cue:hover {
    color: #fff;
  }

  .hero-scroll-cue svg {
    width: 18px;
    height: 18px;
    animation: heroScrollBounce 2.4s cubic-bezier(0.32, 0.72, 0, 1) infinite;
  }

  @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  @keyframes morphBlob { 0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; } 50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; } }
  @keyframes gradientShift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
  @keyframes heroScrollBounce { 0%, 100% { transform: translateY(0); opacity: 0.7; } 50% { transform: translateY(6px); opacity: 1; } }

  @media (max-width: 1024px) {
    .hero-metrics { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero-inner { padding-block: var(--s-20, 5rem) var(--s-12, 3rem); }
    .hero h1 { font-size: clamp(32px, 8vw, 48px); }
    .hero-btns { flex-direction: column; align-items: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-chip,
    .hero h1,
    .hero h1 .accent,
    .hero-sub,
    .hero-btns,
    .hero-metrics,
    .hero-blob,
    .hero-scroll-cue svg {
      animation: none;
    }
  }
</style>
