---
/**
 * @file Gallery.astro
 * @description Responsive image grid (1/2/3 cols) with double-bezel framing,
 *              hover zoom + overlay icon, and a native <dialog> lightbox with
 *              keyboard navigation (←/→/Esc). Honors reduced-motion.
 *
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */

export interface GalleryImage {
  src: string;
  alt: string;
  /** Optional caption shown in the lightbox. */
  caption?: string;
  /** Aspect-ratio override per item (defaults to 4/3). */
  aspect?: string;
}

export interface Props {
  images: readonly GalleryImage[];
  /** Optional id for multiple galleries on the same page. */
  id?: string;
  /** Stagger delay between cards (ms). */
  stagger?: number;
}

const { images, id = 'gallery', stagger = 60 } = Astro.props;
---

<section class="gallery" data-gallery-id={id}>
  <div class="gallery-grid">
    {images.map((image, index) => (
      <figure
        class="gallery-item reveal"
        data-reveal-delay={index * stagger}
        style={`--aspect: ${image.aspect ?? '4 / 3'}`}
      >
        <button
          type="button"
          class="gallery-trigger"
          data-gallery-trigger
          data-index={index}
          aria-label={`Ampliar imagem: ${image.alt}`}
        >
          <span class="gallery-shell" aria-hidden="true">
            <span class="gallery-core">
              <img
                src={image.src}
                alt={image.alt}
                loading="lazy"
                decoding="async"
                width="400"
                height="300"
              />
              <span class="gallery-overlay">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="11" cy="11" r="8"/>
                  <path d="m21 21-4.3-4.3"/>
                  <path d="M11 8v6"/>
                  <path d="M8 11h6"/>
                </svg>
              </span>
            </span>
          </span>
        </button>
        {image.caption && <figcaption>{image.caption}</figcaption>}
      </figure>
    ))}
  </div>

  <dialog class="lightbox" aria-label="Galeria — visualização ampliada">
    <button type="button" class="lightbox-close" data-lightbox-close aria-label="Fechar galeria">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>

    <button type="button" class="lightbox-nav lightbox-prev" data-lightbox-prev aria-label="Imagem anterior">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>

    <figure class="lightbox-figure">
      <img class="lightbox-image" alt="" />
      <figcaption class="lightbox-caption"></figcaption>
    </figure>

    <button type="button" class="lightbox-nav lightbox-next" data-lightbox-next aria-label="Próxima imagem">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>

    <span class="lightbox-counter" aria-live="polite"></span>
  </dialog>
</section>

<script is:inline define:vars={{ images, id }}>
  (() => {
    const root = document.querySelector(`[data-gallery-id="${id}"]`);
    if (!root) return;

    const dialog = root.querySelector('.lightbox');
    const img = root.querySelector('.lightbox-image');
    const caption = root.querySelector('.lightbox-caption');
    const counter = root.querySelector('.lightbox-counter');
    const triggers = root.querySelectorAll('[data-gallery-trigger]');

    let current = 0;

    const render = (index) => {
      const item = images[index];
      if (!item) return;
      current = index;
      img.src = item.src;
      img.alt = item.alt;
      caption.textContent = item.caption || '';
      caption.hidden = !item.caption;
      counter.textContent = `${index + 1} / ${images.length}`;
    };

    let triggerIndex = 0;

    const open = (index) => {
      triggerIndex = index;
      render(index);
      if (typeof dialog.showModal === 'function') {
        dialog.showModal();
      } else {
        dialog.setAttribute('open', '');
      }
      document.body.style.overflow = 'hidden';
      root.querySelector('[data-lightbox-close]')?.focus();
    };

    const close = () => {
      if (typeof dialog.close === 'function') {
        dialog.close();
      } else {
        dialog.removeAttribute('open');
      }
      document.body.style.overflow = '';
      triggers[triggerIndex]?.focus();
    };

    const next = () => render((current + 1) % images.length);
    const prev = () => render((current - 1 + images.length) % images.length);

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const i = Number(trigger.dataset.index || '0');
        open(i);
      });
    });

    root.querySelector('[data-lightbox-close]')?.addEventListener('click', close);
    root.querySelector('[data-lightbox-next]')?.addEventListener('click', next);
    root.querySelector('[data-lightbox-prev]')?.addEventListener('click', prev);

    // Click on backdrop closes the lightbox
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) close();
    });

    document.addEventListener('keydown', (event) => {
      if (!dialog.open) return;
      if (event.key === 'ArrowRight') next();
      if (event.key === 'ArrowLeft') prev();
    });
  })();
</script>

<style>
  .gallery {
    width: 100%;
  }

  /* --- Grid: 1 / 2 / 3 columns --- */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .gallery-item {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .gallery-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    color: inherit;
  }

  .gallery-trigger:focus-visible {
    outline: 2px solid var(--vp-purple, #9b59b6);
    outline-offset: 4px;
    border-radius: var(--radius-xl);
  }

  /* --- Double-bezel: outer shell --- */
  .gallery-shell {
    display: block;
    padding: 6px;
    background: linear-gradient(
      135deg,
      rgb(255 255 255 / 0.6) 0%,
      rgba(155, 89, 182, 0.04) 100%
    );
    border: 1px solid var(--vp-gray-200, #e5e7eb);
    border-radius: calc(var(--radius-xl) + 6px);
    box-shadow: var(--shadow-sm);
    transition:
      transform 350ms cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 350ms cubic-bezier(0.32, 0.72, 0, 1),
      border-color 350ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .gallery-trigger:hover .gallery-shell {
    transform: translateY(-3px);
    box-shadow: var(--shadow-xl);
    border-color: var(--vp-purple-light, #d2b4de);
  }

  .gallery-trigger:active .gallery-shell {
    transform: translateY(-1px) scale(0.99);
  }

  /* --- Inner core --- */
  .gallery-core {
    display: block;
    position: relative;
    aspect-ratio: var(--aspect, 4 / 3);
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--vp-gray-100, #f3f4f6);
    box-shadow: inset 0 1px 1px rgb(255 255 255 / 0.4);
  }

  .gallery-core img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: transform;
  }

  .gallery-trigger:hover .gallery-core img {
    transform: scale(1.05);
  }

  /* --- Hover overlay with zoom icon --- */
  .gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      rgba(108, 52, 131, 0) 0%,
      rgba(155, 89, 182, 0.45) 100%
    );
    opacity: 0;
    transition: opacity 300ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .gallery-overlay svg {
    width: 44px;
    height: 44px;
    color: #fff;
    padding: 10px;
    background-color: rgba(108, 52, 131, 0.85);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-lg);
    transform: scale(0.8);
    transition: transform 300ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .gallery-trigger:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-trigger:hover .gallery-overlay svg {
    transform: scale(1);
  }

  .gallery-item figcaption {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--vp-gray-600, #4b5563);
    text-align: center;
    margin: 0;
  }

  /* --- Lightbox dialog --- */
  .lightbox {
    width: min(96vw, 1200px);
    max-width: 96vw;
    max-height: 92vh;
    margin: auto;
    padding: 0;
    background: var(--vp-gray-900, #111827);
    border: 0;
    border-radius: var(--radius-xl);
    box-shadow: 0 40px 80px -20px rgb(0 0 0 / 0.6);
    color: #fff;
    overflow: visible;
  }

  .lightbox::backdrop {
    background: rgba(17, 24, 39, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .lightbox[open] {
    animation: lightboxIn 280ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  @keyframes lightboxIn {
    from {
      opacity: 0;
      transform: scale(0.96);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .lightbox-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-6);
  }

  .lightbox-image {
    display: block;
    max-width: 100%;
    max-height: 76vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 50px -20px rgb(0 0 0 / 0.5);
  }

  .lightbox-caption {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgb(255 255 255 / 0.85);
    text-align: center;
    max-width: 60ch;
  }

  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: var(--radius-full);
    color: #fff;
    background: rgb(255 255 255 / 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
    transition:
      background-color 200ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lightbox-close:hover,
  .lightbox-nav:hover {
    background: rgb(255 255 255 / 0.22);
    transform: scale(1.06);
  }

  .lightbox-close {
    top: 0.75rem;
    right: 0.75rem;
  }

  .lightbox-prev {
    top: 50%;
    left: -22px;
    transform: translateY(-50%);
  }

  .lightbox-next {
    top: 50%;
    right: -22px;
    transform: translateY(-50%);
  }

  .lightbox-prev:hover { transform: translateY(-50%) scale(1.06); }
  .lightbox-next:hover { transform: translateY(-50%) scale(1.06); }

  .lightbox-close svg,
  .lightbox-nav svg {
    width: 22px;
    height: 22px;
  }

  .lightbox-counter {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.35rem 0.85rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgb(255 255 255 / 0.85);
    background: rgb(0 0 0 / 0.4);
    border-radius: var(--radius-full);
  }

  @media (max-width: 640px) {
    .lightbox-prev,
    .lightbox-next {
      width: 40px;
      height: 40px;
    }
    .lightbox-prev {
      left: 0.5rem;
    }
    .lightbox-next {
      right: 0.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-shell,
    .gallery-core img,
    .gallery-overlay,
    .gallery-overlay svg,
    .lightbox-close,
    .lightbox-nav { transition: none; }

    .gallery-trigger:hover .gallery-shell,
    .gallery-trigger:hover .gallery-core img { transform: none; }

    .lightbox[open] { animation: none; }
  }
</style>
