---
/**
 * @file TestimonialCard.astro
 * @description DS v3 testimonial card with decorative quote, gradient avatar,
 *              and premium hover state.
 */

export interface Props {
  quote: string;
  name: string;
  role: string;
  avatar?: string;
  rating?: 1 | 2 | 3 | 4 | 5;
  /** Stagger delay in ms. */
  delay?: number;
}

const { quote, name, role, avatar, rating, delay = 0 } = Astro.props;

const initials = name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((p) => p.charAt(0).toUpperCase())
  .join('');
---

<figure class="testimonial reveal" data-animate="fade-scale" data-reveal-delay={delay}>
  {rating && (
    <div class="testimonial-rating" aria-label={`Avaliação: ${rating} de 5 estrelas`}>
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill={i < rating ? 'currentColor' : 'none'}
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01Z"/>
        </svg>
      ))}
    </div>
  )}

  <blockquote class="testimonial-text">
    <p>{quote}</p>
  </blockquote>

  <figcaption class="testimonial-author">
    <div class="testimonial-avatar" aria-hidden="true">
      {avatar
        ? <img src={avatar} alt="" loading="lazy" decoding="async" width="44" height="44" />
        : <span>{initials}</span>
      }
    </div>
    <div>
      <div class="testimonial-name">{name}</div>
      <div class="testimonial-role">{role}</div>
    </div>
  </figcaption>
</figure>

<style>
  .testimonial {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--s-4, 1rem);
    padding: var(--s-8, 2rem);
    margin: 0;
    background: #fff;
    border: 1px solid var(--vp-gray-200, var(--color-neutral-200));
    border-radius: var(--r-xl, 24px);
    box-shadow: var(--shadow-md, 0 4px 12px rgba(0, 0, 0, 0.08));
    transition: all var(--t-normal, 300ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .testimonial:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg, 0 12px 32px rgba(0, 0, 0, 0.12));
  }

  .testimonial::before {
    content: '\201C';
    position: absolute;
    top: 12px;
    left: 20px;
    color: var(--vp-purple-light, #d2b4de);
    font-family: var(--font-display);
    font-size: 56px;
    line-height: 1;
    opacity: 0.4;
    pointer-events: none;
  }

  .testimonial-rating {
    display: inline-flex;
    gap: 2px;
    color: var(--vp-gold-deep, #daa520);
    margin-left: auto;
  }

  .testimonial-rating svg {
    width: 18px;
    height: 18px;
  }

  .testimonial-text {
    flex: 1;
    margin: 0;
    padding-top: var(--s-4, 1rem);
  }

  .testimonial-text p {
    margin: 0;
    color: var(--vp-gray-600, var(--color-neutral-700));
    font-family: var(--font-body, var(--font-sans));
    font-size: 15px;
    line-height: 1.8;
    text-wrap: pretty;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--s-3, 0.75rem);
    padding-top: var(--s-3, 0.75rem);
    border-top: 1px solid var(--vp-gray-100, var(--color-neutral-100));
  }

  .testimonial-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex: 0 0 44px;
    overflow: hidden;
    color: #fff;
    background: var(--grad-magic, linear-gradient(135deg, #ff0080 0%, #9b59b6 50%, #50e3c2 100%));
    border-radius: 50%;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    box-shadow: 0 8px 20px rgba(155, 89, 182, 0.2);
  }

  .testimonial-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-name {
    color: var(--vp-gray-800, var(--color-neutral-800));
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
    font-weight: 700;
  }

  .testimonial-role {
    color: var(--vp-gray-400, var(--color-neutral-500));
    font-family: var(--font-body, var(--font-sans));
    font-size: 12px;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial { transition: none; }
    .testimonial:hover { transform: none; }
  }
</style>
