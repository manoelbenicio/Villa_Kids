---
/**
 * @file TestimonialCard.astro
 * @description Card with decorative quote glyph, italic quote, avatar (48px),
 *              name (bold) and role (small). Optional 5-star rating.
 *
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */

export interface Props {
  quote: string;
  name: string;
  role: string;
  avatar?: string;
  rating?: 1 | 2 | 3 | 4 | 5;
  /** Stagger delay in ms. */
  delay?: number;
}

const { quote, name, role, avatar, rating, delay = 0 } = Astro.props;

const initials = name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((p) => p.charAt(0).toUpperCase())
  .join('');
---

<figure class="testimonial reveal" data-reveal-delay={delay}>
  <svg
    class="testimonial-quote"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M9.583 17.321C8.553 16.227 8 15 8 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm-9 0C-.447 16.227-1 15-1 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" transform="translate(2 0)"/>
  </svg>

  {rating && (
    <div class="testimonial-rating" aria-label={`Avaliação: ${rating} de 5 estrelas`}>
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill={i < rating ? 'currentColor' : 'none'}
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01Z"/>
        </svg>
      ))}
    </div>
  )}

  <blockquote class="testimonial-quote-text">
    <p>{quote}</p>
  </blockquote>

  <figcaption class="testimonial-author">
    <div class="testimonial-avatar" aria-hidden="true">
      {avatar
        ? <img src={avatar} alt="" loading="lazy" decoding="async" />
        : <span class="testimonial-initials">{initials}</span>
      }
    </div>
    <div class="testimonial-meta">
      <span class="testimonial-name">{name}</span>
      <span class="testimonial-role">{role}</span>
    </div>
  </figcaption>
</figure>

<style>
  .testimonial {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
    background-color: var(--color-surface);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    transition:
      transform 300ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 300ms cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    isolation: isolate;
  }

  .testimonial:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  /* --- Decorative quote glyph --- */
  .testimonial-quote {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 64px;
    height: 64px;
    color: var(--color-accent-200);
    opacity: 0.6;
    z-index: -1;
    pointer-events: none;
  }

  /* --- Rating --- */
  .testimonial-rating {
    display: inline-flex;
    gap: 2px;
    color: var(--color-accent-500);
  }
  .testimonial-rating svg {
    width: 18px;
    height: 18px;
  }

  /* --- Quote text --- */
  .testimonial-quote-text {
    margin: 0;
    flex: 1;
  }

  .testimonial-quote-text p {
    margin: 0;
    font-family: var(--font-sans);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--color-neutral-700);
    text-wrap: pretty;
  }

  /* --- Author --- */
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-neutral-100);
  }

  .testimonial-avatar {
    flex: 0 0 48px;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--color-primary-100) 0%,
      var(--color-primary-200) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-800);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-base);
  }

  .testimonial-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-initials {
    user-select: none;
  }

  .testimonial-meta {
    display: flex;
    flex-direction: column;
    gap: 0;
    line-height: 1.3;
  }

  .testimonial-name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-primary-800);
  }

  .testimonial-role {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial {
      transition: none;
    }
    .testimonial:hover {
      transform: none;
    }
  }
</style>
