---
/**
 * @file CTAButton.astro
 * @description Universal call-to-action button with 4 variants
 *              (primary, secondary, whatsapp, outline) and 3 sizes
 *              (sm, md, lg). Renders as <a> for navigation/whatsapp links
 *              and supports external link semantics.
 *
 *              Visual hooks:
 *              - hover: scale(1.02) + elevated shadow
 *              - 200ms transition
 *              - whatsapp variant ships with inline WhatsApp glyph
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */

export interface Props {
  text: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'whatsapp' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  /** When true, opens in a new tab and adds rel="noopener noreferrer". */
  external?: boolean;
  /** Extra class names, appended last so they can override defaults. */
  class?: string;
  /** Aria-label override (defaults to `text`). */
  ariaLabel?: string;
}

const {
  text,
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: extraClass = '',
  ariaLabel,
} = Astro.props;

const sizeClass = {
  sm: 'cta-sm',
  md: 'cta-md',
  lg: 'cta-lg',
}[size];

const variantClass = `cta-${variant}`;

const isWhatsApp = variant === 'whatsapp';
const target = external || isWhatsApp ? '_blank' : undefined;
const rel = external || isWhatsApp ? 'noopener noreferrer' : undefined;
---

<a
  href={href}
  class:list={['cta', variantClass, sizeClass, extraClass]}
  target={target}
  rel={rel}
  aria-label={ariaLabel ?? text}
>
  {isWhatsApp && (
    <svg
      class="cta-icon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
  )}
  <span class="cta-text">{text}</span>
  {!isWhatsApp && (
    <svg
      class="cta-arrow"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
    </svg>
  )}
</a>

<style>
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    line-height: 1;
    border-radius: var(--radius-full);
    transition:
      transform 200ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 200ms cubic-bezier(0.4, 0, 0.2, 1),
      background-color 200ms cubic-bezier(0.4, 0, 0.2, 1),
      color 200ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    user-select: none;
    text-decoration: none;
    white-space: nowrap;
    will-change: transform;
  }

  .cta:hover {
    transform: translateY(-1px) scale(1.02);
  }

  .cta:active {
    transform: translateY(0) scale(0.99);
  }

  .cta:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: 3px;
  }

  /* --- Sizes --- */
  .cta-sm {
    font-size: var(--text-sm);
    padding: 0.55rem 1.1rem;
  }

  .cta-md {
    font-size: var(--text-base);
    padding: 0.85rem 1.6rem;
  }

  .cta-lg {
    font-size: var(--text-lg);
    padding: 1.05rem 2rem;
  }

  /* --- Variant: Primary (gradient teal + glow on hover) --- */
  .cta-primary {
    color: #fff;
    background: linear-gradient(
      135deg,
      var(--color-primary-700) 0%,
      var(--color-primary-500) 100%
    );
    box-shadow: var(--shadow-md);
  }
  .cta-primary:hover {
    box-shadow:
      0 12px 24px -8px rgb(0 109 132 / 0.45),
      0 0 28px rgb(0 109 132 / 0.25);
    color: #fff;
  }

  /* --- Variant: Secondary (solid surface, teal text) --- */
  .cta-secondary {
    color: var(--color-primary-700);
    background-color: var(--color-surface);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-primary-100);
  }
  .cta-secondary:hover {
    color: var(--color-primary-800);
    box-shadow: var(--shadow-lg);
  }

  /* --- Variant: WhatsApp (#25D366) --- */
  .cta-whatsapp {
    color: #fff;
    background-color: #25d366;
    box-shadow: 0 6px 16px -4px rgb(37 211 102 / 0.45);
  }
  .cta-whatsapp:hover {
    color: #fff;
    background-color: #1ebe5a;
    box-shadow:
      0 12px 24px -8px rgb(37 211 102 / 0.55),
      0 0 0 4px rgb(37 211 102 / 0.18);
  }

  /* --- Variant: Outline (transparent, teal border, fills on hover) --- */
  .cta-outline {
    color: var(--color-primary-50);
    background-color: transparent;
    border: 1.5px solid currentColor;
  }
  .cta-outline:hover {
    color: var(--color-primary-900);
    background-color: var(--color-primary-50);
    border-color: var(--color-primary-50);
  }

  /* --- Icons --- */
  .cta-icon {
    width: 1.1em;
    height: 1.1em;
    flex: 0 0 auto;
  }

  .cta-arrow {
    width: 1em;
    height: 1em;
    flex: 0 0 auto;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cta:hover .cta-arrow {
    transform: translateX(3px);
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .cta,
    .cta-arrow {
      transition: none;
    }
    .cta:hover {
      transform: none;
    }
  }
</style>
