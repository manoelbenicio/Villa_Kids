---
/**
 * @file CTAButton.astro
 * @description DS v3 premium CTA button. Preserves the previous API while
 *              emitting global DS classes (`btn`, `btn-magic`, `btn-white`,
 *              `btn-outline`, `btn-lg`) wherever possible.
 */

export interface Props {
  text: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'whatsapp' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  /** When true, opens in a new tab and adds rel="noopener noreferrer". */
  external?: boolean;
  /** Extra class names, appended last so they can override defaults. */
  class?: string;
  /** Aria-label override (defaults to `text`). */
  ariaLabel?: string;
}

const {
  text,
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: extraClass = '',
  ariaLabel,
} = Astro.props;

const dsVariantClass = {
  primary: 'btn-magic',
  secondary: 'btn-white',
  whatsapp: 'btn-whatsapp',
  outline: 'btn-outline',
}[variant];

const sizeClass = size === 'lg' ? 'btn-lg' : size === 'sm' ? 'btn-sm' : '';
const isWhatsApp = variant === 'whatsapp';
const target = external || isWhatsApp ? '_blank' : undefined;
const rel = external || isWhatsApp ? 'noopener noreferrer' : undefined;
---

<a
  href={href}
  class:list={['btn', 'cta', dsVariantClass, sizeClass, `cta-${variant}`, extraClass]}
  target={target}
  rel={rel}
  aria-label={ariaLabel ?? text}
>
  {isWhatsApp && (
    <svg
      class="cta-icon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
  )}
  <span class="cta-text">{text}</span>
  {!isWhatsApp && (
    <svg
      class="cta-arrow"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
    </svg>
  )}
</a>

<style>
  .btn {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-2, 0.5rem);
    min-height: 48px;
    padding: 14px 32px;
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
    border: 0;
    border-radius: var(--r-full, var(--radius-full));
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--t-normal, 300ms) var(--ease-spring, cubic-bezier(0.34, 1.56, 0.64, 1));
  }

  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.22);
    border-radius: inherit;
    transform: scale(0);
    opacity: 0;
    pointer-events: none;
  }

  .btn:active::after {
    animation: ripple 450ms ease-out;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn:focus-visible {
    outline: 3px solid rgba(155, 89, 182, 0.35);
    outline-offset: 3px;
  }

  .btn-sm {
    min-height: 40px;
    padding: 10px 24px;
    font-size: 13px;
  }

  .btn-lg {
    min-height: 56px;
    padding: 18px 40px;
    font-size: 16px;
  }

  .btn-magic {
    color: #fff;
    background: var(--grad-magic, linear-gradient(135deg, #ff0080 0%, #9b59b6 50%, #50e3c2 100%));
    background-size: 200% 200%;
    animation: gradientShift 3s ease infinite;
    box-shadow: 0 4px 20px rgba(255, 0, 128, 0.25);
  }

  .btn-magic:hover {
    color: #fff;
    box-shadow: var(--shadow-glow-magenta, 0 0 60px rgba(255, 0, 128, 0.2));
  }

  .btn-white {
    color: var(--vp-purple-deep, #6c3483);
    background: #fff;
    border: 1px solid rgba(155, 89, 182, 0.12);
    box-shadow: var(--shadow-lg, 0 12px 32px rgba(0, 0, 0, 0.12));
  }

  .btn-white:hover {
    color: var(--vp-purple-deep, #6c3483);
    box-shadow: var(--shadow-xl, 0 24px 48px rgba(0, 0, 0, 0.16));
  }

  .btn-outline {
    color: #fff;
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.55);
  }

  .btn-outline:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
  }

  .btn-whatsapp {
    color: #fff;
    background: linear-gradient(135deg, #25d366 0%, var(--vp-green, #7ed321) 100%);
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.28);
  }

  .btn-whatsapp:hover {
    color: #fff;
    box-shadow: 0 14px 32px rgba(37, 211, 102, 0.35);
  }

  .cta-icon,
  .cta-arrow {
    width: 1.1em;
    height: 1.1em;
    flex: 0 0 auto;
    position: relative;
    z-index: 1;
  }

  .cta-text {
    position: relative;
    z-index: 1;
  }

  .cta-arrow {
    transition: transform var(--t-fast, 200ms) var(--ease-smooth, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .btn:hover .cta-arrow {
    transform: translateX(3px);
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes ripple {
    from { opacity: 0.45; transform: scale(0); }
    to { opacity: 0; transform: scale(2.8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn,
    .cta-arrow {
      animation: none;
      transition: none;
    }
    .btn:hover {
      transform: none;
    }
  }
</style>
