---
/**
 * @file Header.astro
 * @description DS v3 glassmorphism navbar with mobile overlay navigation.
 */
import { schoolInfo } from '../data/school-info.ts';
import { mainNav } from '../data/navigation.ts';
import CTAButton from './CTAButton.astro';
---

<header class="nav site-header" data-state="top">
  <a href="#main-content" class="skip-to-content">Pular para o conteúdo</a>

  <a class="nav-logo" href="/" aria-label={`${schoolInfo.name} - voltar à página inicial`}>
    <span class="nav-logo-mark" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M16 3.5 19.4 11l8.1.9-6 5.5 1.7 8-7.2-4.1-7.2 4.1 1.7-8-6-5.5 8.1-.9L16 3.5Z" fill="currentColor"/>
      </svg>
    </span>
    <span>Villa Prime</span>
  </a>

  <nav class="nav-menu" aria-label="Navegação principal">
    {mainNav
      .filter((link) => !link.highlight)
      .map((link) => (
        <a
          href={link.href}
          class:list={[Astro.url.pathname === link.href ? 'is-current' : '']}
          aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
  </nav>

  <div class="nav-actions">
    <CTAButton text="Matrículas" href="/matriculas/" variant="primary" size="sm" class="nav-cta" />
  </div>

  <button
    class="nav-toggle"
    type="button"
    aria-label="Abrir menu de navegação"
    aria-expanded="false"
    aria-controls="mobile-menu"
    data-menu-toggle
  >
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>

  <div id="mobile-menu" class="mobile-menu" data-menu hidden inert>
    <nav aria-label="Navegação principal (mobile)">
      <ul>
        {mainNav.map((link, i) => (
          <li style={`--i: ${i}`}>
            <a
              href={link.href}
              class:list={[
                'mobile-link',
                link.highlight ? 'is-highlight' : '',
                Astro.url.pathname === link.href ? 'is-current' : '',
              ]}
              data-menu-link
            >
              {link.label}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <div class="mobile-menu-footer">
        <a href={`tel:${schoolInfo.phoneRaw}`} class="mobile-meta">{schoolInfo.phone}</a>
        <a href={`mailto:${schoolInfo.email}`} class="mobile-meta">{schoolInfo.email}</a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector('.site-header');
    const toggle = document.querySelector('[data-menu-toggle]');
    const menu = document.querySelector('[data-menu]');
    const links = document.querySelectorAll('[data-menu-link]');
    if (!header || !toggle || !menu) return;

    const updateScrollState = () => {
      const scrolled = window.scrollY > 16;
      header.dataset.state = scrolled ? 'scrolled' : 'top';
      header.classList.toggle('scrolled', scrolled);
    };
    updateScrollState();

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      requestAnimationFrame(() => {
        updateScrollState();
        ticking = false;
      });
      ticking = true;
    }, { passive: true });

    const setOpen = (open) => {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Fechar menu de navegação' : 'Abrir menu de navegação');
      header.dataset.menu = open ? 'open' : 'closed';
      if (open) {
        menu.hidden = false;
        menu.removeAttribute('inert');
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(() => { menu.dataset.visible = 'true'; });
      } else {
        menu.dataset.visible = 'false';
        menu.setAttribute('inert', '');
        document.body.style.overflow = '';
        window.setTimeout(() => {
          if (menu.dataset.visible === 'false') menu.hidden = true;
        }, 320);
      }
    };

    toggle.addEventListener('click', () => setOpen(toggle.getAttribute('aria-expanded') !== 'true'));
    links.forEach((link) => link.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });
  })();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9999;
    width: 100%;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-6, 1.5rem);
    padding: 0 var(--s-8, 2rem);
    color: var(--vp-gray-700, var(--color-neutral-700));
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-bottom: 1px solid rgba(155, 89, 182, 0.06);
    transition: all var(--t-normal, 300ms) var(--ease-smooth, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .nav.scrolled {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: var(--shadow-md, 0 4px 12px rgba(0, 0, 0, 0.08));
  }

  .skip-to-content {
    position: absolute;
    top: -100%;
    left: 50%;
    z-index: 10000;
    transform: translateX(-50%);
    padding: var(--s-3, 0.75rem) var(--s-6, 1.5rem);
    color: #fff;
    background: var(--vp-purple-deep, #6c3483);
    border-radius: 0 0 var(--r-md, 12px) var(--r-md, 12px);
  }

  .skip-to-content:focus { top: 0; }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--s-3, 0.75rem);
    flex: 0 0 auto;
    color: inherit;
    text-decoration: none;
  }

  .nav-logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    color: var(--vp-gold, #ffd700);
    background: var(--grad-magic, linear-gradient(135deg, #ff0080 0%, #9b59b6 50%, #50e3c2 100%));
    border-radius: 50%;
    box-shadow: 0 8px 24px rgba(155, 89, 182, 0.18);
  }

  .nav-logo-mark svg {
    width: 22px;
    height: 22px;
    color: #fff;
  }

  .nav-logo span:last-child {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    background: var(--grad-magic, linear-gradient(135deg, #ff0080 0%, #9b59b6 50%, #50e3c2 100%));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-6, 1.5rem);
    flex: 1 1 auto;
  }

  .nav-menu a {
    position: relative;
    color: var(--vp-gray-600, var(--color-neutral-600));
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: color var(--t-fast, 200ms) ease;
  }

  .nav-menu a:hover,
  .nav-menu a.is-current {
    color: var(--vp-purple, #9b59b6);
  }

  .nav-menu a::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--grad-magic, linear-gradient(135deg, #ff0080 0%, #9b59b6 50%, #50e3c2 100%));
    border-radius: var(--r-full, var(--radius-full));
    transition: width var(--t-normal, 300ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .nav-menu a:hover::after,
  .nav-menu a.is-current::after {
    width: 100%;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0;
    color: var(--vp-purple-deep, #6c3483);
    background: rgba(155, 89, 182, 0.08);
    border: 1px solid rgba(155, 89, 182, 0.18);
    border-radius: var(--r-md, 12px);
    cursor: pointer;
  }

  .nav-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: var(--r-full, var(--radius-full));
    transition: transform var(--t-normal, 300ms) var(--ease-smooth, cubic-bezier(0.4, 0, 0.2, 1)), opacity var(--t-fast, 200ms) ease;
  }

  .site-header[data-menu="open"] .nav-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .site-header[data-menu="open"] .nav-toggle span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .site-header[data-menu="open"] .nav-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: -1;
    display: flex;
    align-items: flex-start;
    padding: 6rem var(--s-6, 1.5rem) var(--s-8, 2rem);
    color: #fff;
    background: rgba(17, 24, 39, 0.94);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    opacity: 0;
    transition: opacity var(--t-normal, 300ms) var(--ease-smooth, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .mobile-menu[data-visible="true"] { opacity: 1; }

  .mobile-menu nav {
    width: min(100%, var(--container-max, 1280px));
    margin: 0 auto;
  }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: var(--s-1, 0.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--s-4, 1rem) var(--s-3, 0.75rem);
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(28px, 8vw, 44px);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 400ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)), transform 400ms var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)), color var(--t-fast, 200ms) ease;
  }

  .mobile-menu[data-visible="true"] .mobile-link {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--i) * 60ms + 80ms);
  }

  .mobile-link:hover,
  .mobile-link.is-current,
  .mobile-link.is-highlight {
    color: var(--vp-cyan, #50e3c2);
  }

  .mobile-link svg {
    width: 22px;
    height: 22px;
    color: rgba(255, 255, 255, 0.62);
  }

  .mobile-menu-footer {
    display: flex;
    flex-direction: column;
    gap: var(--s-1, 0.25rem);
    margin-top: var(--s-8, 2rem);
    padding-top: var(--s-4, 1rem);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mobile-meta {
    color: rgba(255, 255, 255, 0.72);
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
  }

  .mobile-meta:hover { color: #fff; }

  @media (max-width: 1024px) {
    .nav-menu,
    .nav-actions { display: none; }
    .nav-toggle { display: inline-flex; }
  }

  @media (max-width: 768px) {
    .nav { padding: 0 var(--s-4, 1rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav,
    .nav-menu a,
    .nav-menu a::after,
    .nav-toggle span,
    .mobile-menu,
    .mobile-link {
      transition: none;
    }
  }
</style>
