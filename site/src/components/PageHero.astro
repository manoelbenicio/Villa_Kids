---
/**
 * @file PageHero.astro
 * @description Compact hero banner for internal pages. Includes breadcrumb,
 *              optional eyebrow, h1, and an optional subtitle. Uses a
 *              gradient + halo background (no parallax) consistent with
 *              the homepage hero, but scaled down for internal pages.
 *
 *              Schema.org BreadcrumbList JSON-LD is automatically emitted
 *              from the `breadcrumbs` prop.
 *
 * @author GEMINI-UX
 * @phase 4
 * @created 2026-05-17T21:34:00Z
 */
import { schoolInfo } from '../data/school-info.ts';

export interface Crumb {
  label: string;
  href?: string;
}

export interface Props {
  /** Optional decorative eyebrow tag above H1. */
  eyebrow?: string;
  /** Required H1. */
  title: string;
  /** Optional descriptor paragraph below H1. */
  subtitle?: string;
  /** Breadcrumb trail. The last entry is the current page (no href). */
  breadcrumbs: readonly Crumb[];
  /** Optional decorative background image (SVG). */
  backgroundImage?: string;
}

const { eyebrow, title, subtitle, breadcrumbs, backgroundImage } = Astro.props;

// Build Schema.org BreadcrumbList JSON-LD
const siteURL = Astro.site ?? new URL(schoolInfo.url);
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.label,
    ...(crumb.href ? { item: new URL(crumb.href, siteURL).toString() } : {}),
  })),
};

const breadcrumbJson = JSON.stringify(breadcrumbSchema);
const bgStyle = backgroundImage ? `background-image: url('${backgroundImage}');` : '';
---

<section class="page-hero">
  <div class="page-hero-bg" style={bgStyle} aria-hidden="true"></div>
  <div class="page-hero-overlay" aria-hidden="true"></div>
  <div class="page-hero-noise" aria-hidden="true"></div>

  <div class="page-hero-content container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb reveal" aria-label="Trilha de navegação">
      <ol>
        {breadcrumbs.map((crumb, i) => (
          <li>
            {crumb.href ? (
              <a href={crumb.href}>{crumb.label}</a>
            ) : (
              <span aria-current="page">{crumb.label}</span>
            )}
            {i < breadcrumbs.length - 1 && (
              <svg
                class="breadcrumb-sep"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m9 18 6-6-6-6"/>
              </svg>
            )}
          </li>
        ))}
      </ol>
    </nav>

    {eyebrow && (
      <span class="page-hero-eyebrow reveal" data-reveal-delay="80">
        <span class="page-hero-eyebrow-dot" aria-hidden="true"></span>
        {eyebrow}
      </span>
    )}

    <h1 class="page-hero-title reveal" data-reveal-delay="160">{title}</h1>

    {subtitle && (
      <p class="page-hero-subtitle reveal" data-reveal-delay="240">{subtitle}</p>
    )}
  </div>
</section>

<script type="application/ld+json" set:html={breadcrumbJson} />

<style>
  .page-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    padding-block: clamp(6rem, 14vh, 8rem) clamp(3rem, 7vh, 5rem);
    background-color: var(--vp-purple-deep, #6c3483);
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: -2;
    opacity: 0.65;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        135deg,
        rgba(108, 52, 131, 0.78) 0%,
        rgba(155, 89, 182, 0.72) 60%,
        rgba(187, 143, 206, 0.55) 100%
      ),
      radial-gradient(
        ellipse at top right,
        rgba(255, 215, 0, 0.18) 0%,
        transparent 55%
      );
    z-index: -1;
    pointer-events: none;
  }

  .page-hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    mix-blend-mode: overlay;
  }

  .page-hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
    max-width: 60rem;
    position: relative;
    z-index: 1;
  }

  /* --- Breadcrumb --- */
  .breadcrumb {
    margin-bottom: var(--space-1);
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumb li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.7);
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .breadcrumb a:hover {
    color: var(--vp-cyan, #50e3c2);
  }

  .breadcrumb [aria-current="page"] {
    color: #fff;
  }

  .breadcrumb-sep {
    width: 12px;
    height: 12px;
    color: rgb(255 255 255 / 0.4);
  }

  /* --- Eyebrow pill --- */
  .page-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.16);
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .page-hero-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--vp-gold, #ffd700);
    box-shadow: 0 0 12px rgba(255, 215, 0, 0.6);
  }

  /* --- Title & subtitle --- */
  .page-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.6vw + 1rem, 3.75rem);
    line-height: 1.1;
    color: #fff;
    margin: 0;
    letter-spacing: -0.02em;
    text-wrap: balance;
    text-shadow: 0 2px 24px rgb(0 0 0 / 0.25);
  }

  .page-hero-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.6vw + 0.85rem, 1.2rem);
    line-height: 1.6;
    color: rgb(255 255 255 / 0.85);
    max-width: 44rem;
    margin: 0;
    text-wrap: pretty;
  }
</style>
