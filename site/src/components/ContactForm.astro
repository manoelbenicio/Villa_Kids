---
/**
 * @file ContactForm.astro
 * @description DS v3 contact form using `form-grid`, `form-label`,
 *              `form-input`, `form-full`, and premium submit button classes.
 */
import { schoolInfo } from '../data/school-info.ts';

export interface Props {
  /** Form submission endpoint (Formspree, /api/contact, etc.). */
  action?: string;
  /** Form id (useful when multiple forms per page). */
  id?: string;
}

const { action = '/api/contact', id = 'contact-form' } = Astro.props;
---

<form
  id={id}
  class="contact-form glass-light reveal"
  method="POST"
  action={action}
  novalidate
  data-animate="fade-scale"
  data-school-whatsapp={schoolInfo.whatsapp}
>
  <fieldset class="form-grid">
    <legend class="sr-only">Dados de contato</legend>

    <div class="form-field">
      <label class="form-label" for={`${id}-nome`}>Nome completo *</label>
      <input
        class="form-input"
        type="text"
        name="nome"
        id={`${id}-nome`}
        placeholder="Seu nome"
        required
        minlength="2"
        autocomplete="name"
        aria-describedby={`${id}-nome-error`}
      />
      <span class="form-error" id={`${id}-nome-error`} aria-live="polite"></span>
    </div>

    <div class="form-field">
      <label class="form-label" for={`${id}-email`}>E-mail *</label>
      <input
        class="form-input"
        type="email"
        name="email"
        id={`${id}-email`}
        placeholder="seu@email.com"
        required
        autocomplete="email"
        aria-describedby={`${id}-email-error`}
      />
      <span class="form-error" id={`${id}-email-error`} aria-live="polite"></span>
    </div>

    <div class="form-field">
      <label class="form-label" for={`${id}-telefone`}>Telefone / WhatsApp *</label>
      <input
        class="form-input"
        type="tel"
        name="telefone"
        id={`${id}-telefone`}
        placeholder="(00) 00000-0000"
        required
        inputmode="tel"
        autocomplete="tel"
        aria-describedby={`${id}-telefone-error`}
      />
      <span class="form-error" id={`${id}-telefone-error`} aria-live="polite"></span>
    </div>

    <div class="form-field">
      <label class="form-label" for={`${id}-turma`}>Turma de interesse *</label>
      <select
        class="form-input"
        name="turma"
        id={`${id}-turma`}
        required
        aria-describedby={`${id}-turma-error`}
      >
        <option value="" disabled selected>Selecione...</option>
        <option value="bercario">Berçário (4 meses a 1 ano)</option>
        <option value="maternal-1">Maternal I (1 a 2 anos)</option>
        <option value="maternal-2">Maternal II (2 a 3 anos)</option>
        <option value="infantil-1">Infantil I (4 anos)</option>
        <option value="infantil-2">Infantil II (5 anos)</option>
        <option value="indeciso">Ainda em dúvida</option>
      </select>
      <span class="form-error" id={`${id}-turma-error`} aria-live="polite"></span>
    </div>

    <div class="form-field form-full">
      <label class="form-label" for={`${id}-mensagem`}>Mensagem *</label>
      <textarea
        class="form-input form-textarea"
        name="mensagem"
        id={`${id}-mensagem`}
        rows="4"
        placeholder="Conte-nos sobre seu filho e o que você deseja conhecer..."
        required
        minlength="10"
        aria-describedby={`${id}-mensagem-error`}
      ></textarea>
      <span class="form-error" id={`${id}-mensagem-error`} aria-live="polite"></span>
    </div>
  </fieldset>

  <div class="honeypot" aria-hidden="true">
    <label for={`${id}-website`}>Website (deixe em branco)</label>
    <input type="text" name="website" id={`${id}-website`} tabindex="-1" autocomplete="off" />
  </div>

  <label class="form-consent">
    <input
      type="checkbox"
      name="consent"
      id={`${id}-consent`}
      required
      aria-describedby={`${id}-consent-error`}
    />
    <span>
      Concordo em ser contatado(a) pelo Colégio Villa Prime e li a
      <a href="/politica-de-privacidade/">Política de Privacidade</a>.
    </span>
  </label>
  <span class="form-error form-consent-error" id={`${id}-consent-error`} aria-live="polite"></span>

  <button type="submit" class="btn btn-magic btn-lg form-submit">
    <span class="form-submit-text">Enviar mensagem</span>
    <span class="form-submit-loading" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M21 12a9 9 0 1 1-6.22-8.55"/>
      </svg>
    </span>
  </button>

  <p class="form-status" role="status" aria-live="polite"></p>
</form>

<script>
  const forms = document.querySelectorAll<HTMLFormElement>('.contact-form');
  forms.forEach((form) => {
    const status = form.querySelector<HTMLElement>('.form-status');
    const submit = form.querySelector<HTMLButtonElement>('.form-submit');
    const setError = (field: HTMLElement, msg: string) => {
      const id = field.getAttribute('aria-describedby');
      if (!id) return;
      const node = document.getElementById(id);
      if (node) node.textContent = msg;
      field.setAttribute('aria-invalid', msg ? 'true' : 'false');
    };

    const messageFor = (field: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement): string => {
      if (field.name === 'telefone') {
        const digits = field.value.replace(/\D/g, '');
        if (digits.length < 10) return 'Informe um telefone com DDD.';
      }
      if (field.validity.valueMissing) return 'Campo obrigatório.';
      if (field.validity.typeMismatch && field instanceof HTMLInputElement && field.type === 'email') {
        return 'Informe um e-mail válido.';
      }
      if (field.validity.tooShort) {
        return `Informe pelo menos ${field.getAttribute('minlength')} caracteres.`;
      }
      if (!field.checkValidity()) return 'Por favor, preencha este campo corretamente.';
      return '';
    };

    const validate = (): boolean => {
      let ok = true;
      form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
        'input[required], select[required], textarea[required]'
      ).forEach((field) => {
        if (field.name === 'consent') {
          const cb = field as HTMLInputElement;
          if (!cb.checked) {
            setError(cb, 'Confirme o consentimento para contato.');
            ok = false;
          } else {
            setError(cb, '');
          }
          return;
        }
        const error = messageFor(field);
        if (error) {
          setError(field, error);
          ok = false;
        } else {
          setError(field, '');
        }
      });
      return ok;
    };

    form.addEventListener('submit', (e) => {
      const honey = form.querySelector<HTMLInputElement>('input[name="website"]');
      if (honey?.value) {
        e.preventDefault();
        return;
      }

      if (!validate()) {
        e.preventDefault();
        if (status) status.textContent = 'Verifique os campos destacados antes de enviar.';
        return;
      }

      if (submit) {
        submit.classList.add('is-loading');
        submit.disabled = true;
      }
      if (status) status.textContent = 'Enviando sua mensagem...';
    });

    form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('input, textarea, select').forEach((field) => {
      field.addEventListener('input', () => setError(field, ''));
      field.addEventListener('blur', () => {
        if (!field.required) return;
        const error = messageFor(field);
        if (error) setError(field, error);
      });
    });
  });
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--s-6, 1.5rem);
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
    padding: var(--s-8, 2rem);
    box-shadow: var(--shadow-lg, 0 12px 32px rgba(0, 0, 0, 0.12));
  }

  .glass-light {
    background: rgba(255, 255, 255, 0.74);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(155, 89, 182, 0.08);
    border-radius: var(--r-xl, 24px);
  }

  .contact-form fieldset {
    border: 0;
    margin: 0;
    padding: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-6, 1.5rem);
  }

  .form-full {
    grid-column: 1 / -1;
  }

  .form-label {
    display: block;
    margin-bottom: var(--s-2, 0.5rem);
    color: var(--vp-gray-700, var(--color-neutral-700));
    font-family: var(--font-body, var(--font-sans));
    font-size: 13px;
    font-weight: 700;
  }

  .form-input {
    width: 100%;
    padding: 14px 18px;
    color: var(--vp-gray-800, var(--color-neutral-800));
    background: var(--vp-gray-50, var(--color-neutral-50));
    border: 1.5px solid var(--vp-gray-200, var(--color-neutral-200));
    border-radius: var(--r-md, 12px);
    outline: none;
    font-family: var(--font-body, var(--font-sans));
    font-size: 15px;
    transition: all var(--t-fast, 200ms) ease;
  }

  .form-input:focus {
    border-color: var(--vp-purple, #9b59b6);
    box-shadow: 0 0 0 4px rgba(155, 89, 182, 0.08);
    background: #fff;
  }

  .form-input::placeholder { color: var(--vp-gray-400, var(--color-neutral-400)); }
  .form-textarea { resize: vertical; min-height: 120px; }

  .form-input[aria-invalid="true"],
  .form-consent input[aria-invalid="true"] {
    border-color: var(--vp-error, var(--color-error));
    box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.08);
  }

  .form-error {
    display: block;
    min-height: 1.1rem;
    margin-top: 0.3rem;
    color: var(--vp-error, var(--color-error));
    font-family: var(--font-body, var(--font-sans));
    font-size: 12px;
    line-height: 1.2;
  }

  .form-consent-error {
    margin-top: calc(var(--s-5, 1.25rem) * -1);
  }

  .honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    pointer-events: none;
  }

  .form-consent {
    display: flex;
    gap: var(--s-2, 0.5rem);
    align-items: flex-start;
    color: var(--vp-gray-600, var(--color-neutral-600));
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
    line-height: 1.5;
    cursor: pointer;
  }

  .form-consent input[type="checkbox"] {
    flex: 0 0 auto;
    width: 1.05rem;
    height: 1.05rem;
    margin-top: 0.18rem;
    accent-color: var(--vp-purple, #9b59b6);
    cursor: pointer;
  }

  .form-consent a {
    color: var(--vp-purple, #9b59b6);
    text-decoration: underline;
  }

  .btn {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-2, 0.5rem);
    align-self: center;
    min-height: 56px;
    padding: 18px 40px;
    color: #fff;
    background: var(--grad-magic, linear-gradient(135deg, #ff0080 0%, #9b59b6 50%, #50e3c2 100%));
    background-size: 200% 200%;
    border: 0;
    border-radius: var(--r-full, var(--radius-full));
    font-family: var(--font-body, var(--font-sans));
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(255, 0, 128, 0.25);
    animation: gradientShift 3s ease infinite;
    transition: all var(--t-normal, 300ms) var(--ease-spring, cubic-bezier(0.34, 1.56, 0.64, 1));
  }

  .btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-magenta, 0 0 60px rgba(255, 0, 128, 0.2));
  }

  .form-submit:disabled {
    opacity: 0.72;
    cursor: progress;
  }

  .form-submit-loading {
    display: none;
    width: 1.1rem;
    height: 1.1rem;
    animation: spin 0.8s linear infinite;
  }

  .form-submit-loading svg {
    width: 100%;
    height: 100%;
  }

  .form-submit.is-loading .form-submit-text { opacity: 0.65; }
  .form-submit.is-loading .form-submit-loading { display: inline-block; }

  .form-status {
    min-height: 1.2rem;
    margin: 0;
    color: var(--vp-gray-600, var(--color-neutral-600));
    font-family: var(--font-body, var(--font-sans));
    font-size: 14px;
    text-align: center;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes gradientShift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }

  @media (max-width: 768px) {
    .form-grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn,
    .form-submit-loading,
    .form-input {
      animation: none;
      transition: none;
    }
    .btn:hover:not(:disabled) { transform: none; }
  }
</style>
