---
/**
 * @file FAQ.astro
 * @description Accessible accordion of FAQ items. Uses native <details>
 *              for zero-JS accessibility, augmented with ARIA expanded
 *              state and a chevron rotation animation.
 *
 *              Automatically emits Schema.org FAQPage JSON-LD.
 *
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */
import type { FAQItem } from '../data/faq.ts';
import { faqItems as defaultItems } from '../data/faq.ts';

export interface Props {
  /** Override the default FAQ items. */
  items?: readonly FAQItem[];
  /** When true, emit Schema.org FAQPage JSON-LD (default true). */
  schema?: boolean;
}

const { items = defaultItems, schema = true } = Astro.props;

const jsonLd = schema
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: items.map((it) => ({
        '@type': 'Question',
        name: it.question,
        acceptedAnswer: { '@type': 'Answer', text: it.answer },
      })),
    })
  : null;
---

<div class="faq" role="list">
  {items.map((item, i) => (
    <details class="faq-item reveal" data-reveal-delay={i * 60} role="listitem">
      <summary class="faq-question">
        <span class="faq-question-text">{item.question}</span>
        <span class="faq-chevron" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </span>
      </summary>
      <div class="faq-answer">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>

{jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

<style>
  .faq {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 56rem;
    margin-inline: auto;
  }

  .faq-item {
    background-color: var(--color-surface);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition:
      border-color 250ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 250ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item[open] {
    border-color: var(--color-primary-200);
    box-shadow: var(--shadow-md);
  }

  .faq-item:hover:not([open]) {
    border-color: var(--color-primary-100);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-lg);
    color: var(--color-primary-800);
    list-style: none;
    user-select: none;
    transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hide default <summary> marker (Safari + Firefox) */
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::marker { content: ''; }

  .faq-question-text {
    flex: 1;
    text-wrap: balance;
  }

  .faq-chevron {
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-600);
    background-color: var(--color-primary-50);
    border-radius: var(--radius-full);
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1),
      background-color 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-chevron svg {
    width: 16px;
    height: 16px;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: #fff;
    background-color: var(--color-primary-600);
  }

  .faq-question:focus-visible {
    outline: 2px solid var(--color-primary-500);
    outline-offset: -2px;
    border-radius: var(--radius-lg);
  }

  /* --- Answer --- */
  .faq-answer {
    padding: 0 var(--space-6) var(--space-5);
    animation: faqFadeIn 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-answer p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-neutral-600);
    line-height: 1.7;
  }

  @keyframes faqFadeIn {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .faq-question {
      padding: var(--space-4) var(--space-5);
      font-size: var(--text-base);
    }
    .faq-answer {
      padding: 0 var(--space-5) var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-chevron,
    .faq-item {
      transition: none;
    }
    .faq-answer {
      animation: none;
    }
  }
</style>
