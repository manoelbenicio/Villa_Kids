---
/**
 * @file turmas.astro
 * @description Página /turmas/ — apresenta as 6 turmas oferecidas (Berçário,
 *              Maternal I, Maternal II, Jardim I, Jardim II e Pré) com idade,
 *              capacidade, destaques e imagem ilustrativa do ambiente.
 *
 * @author GEMINI-UX
 * @phase 4
 * @created 2026-05-17T21:34:00Z
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CTAButton from '../components/CTAButton.astro';
import ContactMiniSection from '../components/ContactMiniSection.astro';
import { whatsappLink } from '../data/school-info.ts';

interface Turma {
  name: string;
  age: string;
  capacity: string;
  ratio: string;
  highlights: string[];
  image: string;
  description: string;
  /** Optional: marks the most-searched class for visual emphasis. */
  featured?: boolean;
}

const turmas: Turma[] = [
  {
    name: 'Berçário',
    age: '4 meses a 1 ano',
    capacity: 'Até 8 bebês por turma',
    ratio: '1 educadora para cada 4 bebês',
    image: '/images/ambientes/bercario.svg',
    description:
      'Ambiente acolhedor com cuidados individualizados, estímulo motor e sensorial respeitando o ritmo de sono e alimentação de cada bebê.',
    highlights: [
      'Estimulação sensorial e motora diária',
      'Acompanhamento da alimentação e sono individuais',
      'Comunicação contínua com as famílias via app',
    ],
  },
  {
    name: 'Maternal I',
    age: '1 a 2 anos',
    capacity: 'Até 12 alunos por turma',
    ratio: '1 educadora para cada 6 crianças',
    image: '/images/ambientes/sala-atividades.svg',
    description:
      'Fase da exploração e da fala. Atividades para desenvolver a autonomia, a coordenação motora e a comunicação por meio do brincar.',
    highlights: [
      'Linguagem oral e ampliação de vocabulário',
      'Coordenação motora ampla e fina',
      'Rotinas de cuidado e autonomia (alimentação, higiene)',
    ],
  },
  {
    name: 'Maternal II',
    age: '2 a 3 anos',
    capacity: 'Até 15 alunos por turma',
    ratio: '1 educadora para cada 7 crianças',
    image: '/images/ambientes/playground.svg',
    description:
      'Idade da imaginação simbólica. Trabalhamos a convivência em grupo, a expressão por meio das artes e a iniciação ao letramento.',
    highlights: [
      'Brincadeiras simbólicas e faz de conta',
      'Iniciação ao letramento por meio de histórias',
      'Convivência em grupo e regras compartilhadas',
    ],
    featured: true,
  },
  {
    name: 'Jardim I',
    age: '3 a 4 anos',
    capacity: 'Até 18 alunos por turma',
    ratio: '1 educadora para cada 9 crianças',
    image: '/images/ambientes/multimidia.svg',
    description:
      'Ampliação dos campos de experiência da BNCC. Projetos investigativos, exploração da natureza, das artes e da matemática inicial.',
    highlights: [
      'Projetos investigativos integrados',
      'Letramento e numeracia em contexto',
      'Educação musical e artística',
    ],
  },
  {
    name: 'Jardim II',
    age: '4 a 5 anos',
    capacity: 'Até 20 alunos por turma',
    ratio: '1 educadora para cada 10 crianças',
    image: '/images/ambientes/area-verde.svg',
    description:
      'Pesquisa, autoria e construção de saberes. As crianças investigam temas, registram suas descobertas e desenvolvem o pensamento científico.',
    highlights: [
      'Projetos de autoria das crianças',
      'Iniciação à escrita e leitura',
      'Educação ambiental e cidadania',
    ],
  },
  {
    name: 'Pré',
    age: '5 a 6 anos',
    capacity: 'Até 22 alunos por turma',
    ratio: '1 educadora para cada 11 crianças',
    image: '/images/ambientes/refeitorio.svg',
    description:
      'Preparação para a alfabetização e o ensino fundamental, mantendo o brincar como linguagem central da infância.',
    highlights: [
      'Alfabetização em contexto significativo',
      'Resolução de problemas e raciocínio lógico',
      'Autonomia, organização e protagonismo',
    ],
  },
];
---

<BaseLayout
  title="Nossas Turmas"
  description="Conheça as 6 turmas do Colégio Villa Prime — do Berçário ao Pré (0 a 6 anos). Veja idade, capacidade, razão de educadores por aluno e os destaques pedagógicos de cada faixa etária."
  schemaType="WebPage"
>
  <PageHero
    eyebrow="Educação Infantil 0–6 anos"
    title="Nossas Turmas"
    subtitle="Seis turmas pensadas em cada fase da primeira infância — com turmas reduzidas para garantir atenção individualizada."
    breadcrumbs={[
      { label: 'Início', href: '/' },
      { label: 'Turmas' },
    ]}
    backgroundImage="/images/ambientes/sala-atividades.svg"
  />

  <!-- ============================================================
       Cards das turmas
       ============================================================ -->
  <section class="section container" data-animate>
    <SectionTitle
      tag="Faixas Etárias"
      title="A turma certa para cada momento da infância"
      subtitle="Cada turma é organizada com base no desenvolvimento esperado para a faixa etária, com proporção generosa de educadores por aluno."
    />

    <div class="turmas-grid stagger" data-animate>
      {turmas.map((turma, i) => (
        <article
          class:list={['turma-card', 'reveal', turma.featured ? 'is-featured' : '']}
          data-reveal-delay={i * 70}
         data-animate>
          <div class="turma-image-shell" aria-hidden="true">
            <div class="turma-image-core">
              <img
                src={turma.image}
                alt={`${turma.name} — ${turma.age}`}
                loading="lazy"
                decoding="async"
                width="400"
                height="300"
              />
            </div>
            <span class="turma-age-pill">{turma.age}</span>
          </div>

          <div class="turma-content">
            <header class="turma-header">
              <h2 class="turma-name">{turma.name}</h2>
              {turma.featured && <span class="turma-badge">Mais procurada</span>}
            </header>

            <p class="turma-description">{turma.description}</p>

            <dl class="turma-meta">
              <div class="turma-meta-item">
                <dt>Capacidade</dt>
                <dd>{turma.capacity}</dd>
              </div>
              <div class="turma-meta-item">
                <dt>Razão</dt>
                <dd>{turma.ratio}</dd>
              </div>
            </dl>

            <ul class="turma-highlights">
              {turma.highlights.map((h) => (
                <li>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ============================================================
       CTA — Encontre a turma ideal
       ============================================================ -->
  <section class="cta-banner section-dark" data-animate>
    <div class="cta-banner-glow" aria-hidden="true"></div>
    <div class="container cta-banner-inner reveal" data-animate>
      <span class="cta-banner-eyebrow">
        <span class="cta-banner-eyebrow-dot" aria-hidden="true"></span>
        Próximo Passo
      </span>
      <h2 class="cta-banner-title">Encontre a turma ideal para o seu filho</h2>
      <p class="cta-banner-subtitle">
        Em uma conversa de 15 minutos, ajudamos você a entender qual turma faz
        mais sentido para o momento da sua família.
      </p>
      <div class="cta-banner-actions">
        <CTAButton text="Iniciar Matrícula" href="/matriculas/" variant="primary" size="lg" />
        <CTAButton
          text="Tirar dúvidas no WhatsApp"
          href={whatsappLink('Olá! Gostaria de saber mais sobre as turmas do Villa Prime.')}
          variant="whatsapp"
          size="lg"
        />
      </div>
    </div>
  </section>

  <ContactMiniSection
    title="Em dúvida sobre qual turma escolher?"
    subtitle="Nossa coordenação pedagógica conversa com você para entender o melhor caminho."
  />
</BaseLayout>

<style>
  /* ============================================================
     Turmas grid
     ============================================================ */
  .turmas-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .turmas-grid {
      grid-template-columns: 1fr;
    }
  }

  /* --- Turma card (double-bezel + horizontal layout) --- */
  .turma-card {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 0;
    background-color: var(--color-surface);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      transform 350ms cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 350ms cubic-bezier(0.32, 0.72, 0, 1),
      border-color 350ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .turma-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-xl);
    border-color: var(--vp-purple-light, #D2B4DE);
  }

  .turma-card.is-featured {
    border-color: color-mix(in srgb, var(--vp-gold, #FFD700) 70%, white);
    background: linear-gradient(
      180deg,
      var(--color-surface) 0%,
      color-mix(in srgb, var(--vp-gold, #FFD700) 12%, white) 100%
    );
  }

  @media (max-width: 640px) {
    .turma-card {
      grid-template-columns: 1fr;
    }
  }

  /* --- Image area (left column on desktop, top on mobile) --- */
  .turma-image-shell {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--vp-purple, #9B59B6) 14%, white);
  }

  .turma-image-core {
    width: 100%;
    height: 100%;
  }

  .turma-image-core img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: transform;
  }

  .turma-card:hover .turma-image-core img {
    transform: scale(1.04);
  }

  .turma-age-pill {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.35rem 0.85rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--vp-purple-deep, #6C3483);
    background-color: rgb(255 255 255 / 0.95);
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: var(--shadow-sm);
  }

  /* --- Content area --- */
  .turma-content {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .turma-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .turma-name {
    font-size: var(--text-2xl);
    color: var(--vp-purple-deep, #6C3483);
    margin: 0;
    line-height: 1.2;
  }

  .turma-badge {
    padding: 0.25rem 0.7rem;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background: linear-gradient(
      135deg,
      var(--vp-gold-deep, #DAA520) 0%,
      var(--vp-gold-deep, #DAA520) 100%
    );
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
  }

  .turma-description {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-neutral-600);
    margin: 0;
  }

  /* --- Meta (capacity / ratio) --- */
  .turma-meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    margin: var(--space-2) 0 0;
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-neutral-100);
    border-bottom: 1px solid var(--color-neutral-100);
  }

  @media (max-width: 480px) {
    .turma-meta {
      grid-template-columns: 1fr;
    }
  }

  .turma-meta-item {
    margin: 0;
  }

  .turma-meta-item dt {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-neutral-500);
    margin: 0 0 0.15rem;
  }

  .turma-meta-item dd {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--vp-purple-deep, #6C3483);
    margin: 0;
    line-height: 1.4;
  }

  /* --- Highlights list --- */
  .turma-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .turma-highlights li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-neutral-700);
  }

  .turma-highlights svg {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    margin-top: 0.15rem;
    color: var(--vp-gold-deep, #DAA520);
  }

  /* ============================================================
     CTA banner (shared with proposta-pedagogica style)
     ============================================================ */
  .cta-banner {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    background: var(--grad-hero, linear-gradient(135deg, #6C3483 0%, #9B59B6 40%, #BB8FCE 100%));
    padding-block: clamp(4rem, 9vh, 6rem);
  }

  .cta-banner-glow {
    position: absolute;
    top: -25%;
    right: -15%;
    width: 70%;
    height: 100%;
    background: radial-gradient(ellipse at center, rgb(155 89 182 / 0.18) 0%, transparent 60%);
    pointer-events: none;
    z-index: -1;
  }

  .cta-banner-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    text-align: center;
    max-width: 52rem;
  }

  .cta-banner-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--vp-purple-light, #D2B4DE);
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(210 180 222 / 0.28);
    border-radius: var(--radius-full);
  }

  .cta-banner-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--vp-purple-light, #D2B4DE);
  }

  .cta-banner-title {
    font-size: clamp(1.75rem, 3vw + 1rem, 2.75rem);
    line-height: 1.15;
    color: #fff;
    margin: 0;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .cta-banner-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.6vw + 0.85rem, 1.15rem);
    line-height: 1.6;
    color: rgb(255 255 255 / 0.88);
    margin: 0;
    max-width: 40rem;
    text-wrap: pretty;
  }

  .cta-banner-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  @media (prefers-reduced-motion: reduce) {
    .turma-card,
    .turma-image-core img { transition: none; }
    .turma-card:hover { transform: none; }
    .turma-card:hover .turma-image-core img { transform: none; }
  }
</style>
