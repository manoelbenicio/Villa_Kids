---
/**
 * @file index.astro
 * @description Home page — Colégio Villa Prime. Phase 3 conversion build.
 *              8 sections, mobile-first, scroll-revealed, premium institutional.
 *
 *              Section order:
 *              1. Hero (full-bleed, parallax, eyebrow + double CTA + scroll cue)
 *              2. Sobre a Escola (split 60/40, double-bezel image frame)
 *              3. Pilares Pedagógicos (4 FeatureCards in 2×2 / 1-col stack)
 *              4. Nossos Ambientes (6 cards with photo + glass-dark caption)
 *              5. Galeria (Gallery component with 8 images)
 *              6. Depoimentos (3 TestimonialCards)
 *              7. FAQ Preview (5 questions + CTA to Contato)
 *              8. CTA Final (gradient-warm fullwidth, WhatsApp + tel)
 *
 * @author GEMINI-UX
 * @phase 3
 * @created 2026-05-17T21:23:00Z
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import FeatureCard from '../components/FeatureCard.astro';
import TrustBadge from '../components/TrustBadge.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FAQ from '../components/FAQ.astro';
import Gallery from '../components/Gallery.astro';
import CTAButton from '../components/CTAButton.astro';
import { schoolInfo, whatsappLink } from '../data/school-info.ts';
import { features } from '../data/features.ts';
import { testimonials } from '../data/testimonials.ts';
import { faqItems } from '../data/faq.ts';

// --- Section 4: ambientes ---
const ambientes = [
  {
    name: 'Berçário',
    description: 'Ambiente seguro e aconchegante para os primeiros passos.',
    image: '/images/ambientes/bercario.svg',
  },
  {
    name: 'Sala de Atividades',
    description: 'Espaço pedagógico para descobertas e brincadeiras.',
    image: '/images/ambientes/sala-atividades.svg',
  },
  {
    name: 'Playground',
    description: 'Área externa com brinquedos seguros e estimulantes.',
    image: '/images/ambientes/playground.svg',
  },
  {
    name: 'Refeitório',
    description: 'Cardápio nutritivo elaborado por nutricionista.',
    image: '/images/ambientes/refeitorio.svg',
  },
  {
    name: 'Sala Multimídia',
    description: 'Tecnologia a serviço da aprendizagem significativa.',
    image: '/images/ambientes/multimidia.svg',
  },
  {
    name: 'Área Verde',
    description: 'Contato com a natureza no coração da escola.',
    image: '/images/ambientes/area-verde.svg',
  },
];

// --- Section 5: gallery ---
const galleryImages = [
  { src: '/images/gallery/gal-1.svg', alt: 'Crianças no cotidiano da escola' },
  { src: '/images/gallery/gal-2.svg', alt: 'Atividade artística' },
  { src: '/images/gallery/gal-3.svg', alt: 'Hora da história' },
  { src: '/images/gallery/gal-4.svg', alt: 'Recreação ao ar livre' },
  { src: '/images/gallery/gal-5.svg', alt: 'Momento de alimentação' },
  { src: '/images/gallery/gal-6.svg', alt: 'Soneca e descanso' },
  { src: '/images/gallery/gal-7.svg', alt: 'Movimento e ginástica' },
  { src: '/images/gallery/gal-8.svg', alt: 'Encontro com famílias' },
];

// --- Section 7: only the first 5 FAQs on the home ---
const faqPreview = faqItems.slice(0, 5);
---

<BaseLayout
  title="Educação Infantil Premium em São Paulo · Colégio Villa Prime"
  description={schoolInfo.shortDescription}
  schemaType="Default"
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <Hero
    eyebrow="Educação Infantil · 0 a 6 anos"
    title="Educação que transforma os primeiros anos"
    subtitle="Acolhimento, desenvolvimento integral e segurança em uma escola pensada para a primeira infância — onde cada criança é acompanhada em seu próprio ritmo."
    primaryCta={{ text: 'Agende uma Visita', href: whatsappLink(), whatsapp: true }}
    secondaryCta={{ text: 'Conheça a Escola', href: '#sobre' }}
    backgroundImage="/images/hero/hero-main.svg"
  />

  <!-- ============================================================
       2. SOBRE A ESCOLA — split layout 60/40
       ============================================================ -->
  <section id="sobre" class="section section-sobre">
    <div class="container sobre-grid">
      <div class="sobre-text reveal">
        <span class="eyebrow">Quem Somos</span>
        <h2 class="sobre-heading">
          Uma escola onde cada criança floresce no seu próprio tempo
        </h2>
        <p class="sobre-lead">
          Acreditamos que a educação infantil é o alicerce de uma vida inteira. No
          Colégio Villa Prime, cuidamos das crianças de 0 a 6 anos com uma proposta
          pedagógica sólida, ambientes projetados para a infância e um cuidado que
          se nota em cada detalhe.
        </p>
        <p class="sobre-body">
          Aqui, a aprendizagem acontece pelo brincar, pela escuta e pela construção
          de vínculos. Nossas turmas são reduzidas para garantir atenção
          individualizada, e a equipe pedagógica trabalha em parceria próxima com as
          famílias — porque acreditamos que a confiança nasce da transparência e da
          presença diária.
        </p>

        <div class="sobre-pillars">
          <div class="sobre-pillar">
            <span class="sobre-pillar-num">15+</span>
            <span class="sobre-pillar-label">Anos cuidando da primeira infância</span>
          </div>
          <div class="sobre-pillar">
            <span class="sobre-pillar-num">1:6</span>
            <span class="sobre-pillar-label">Razão professor por aluno</span>
          </div>
          <div class="sobre-pillar">
            <span class="sobre-pillar-num">500+</span>
            <span class="sobre-pillar-label">Famílias que já confiaram em nós</span>
          </div>
        </div>

        <div class="sobre-cta">
          <CTAButton
            text="Conheça nossa proposta"
            href="/proposta-pedagogica/"
            variant="primary"
            size="md"
          />
        </div>
      </div>

      <div class="sobre-image reveal" data-reveal-delay="120">
        <div class="sobre-image-shell" aria-hidden="true">
          <div class="sobre-image-core">
            <img
              src="/images/sobre/sobre-main.svg"
              alt="Educação que acolhe e desenvolve no Colégio Villa Prime"
              loading="lazy"
              decoding="async"
              width="600"
              height="400"
            />
          </div>
        </div>
        <div class="sobre-image-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 21s-7-4.5-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9Z"/>
          </svg>
          <span>Cuidado<br/>Premium</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. PILARES PEDAGÓGICOS
       ============================================================ -->
  <section id="pilares" class="section section-muted">
    <div class="container">
      <SectionTitle
        tag="Nossos Pilares"
        title="Quatro fundamentos que sustentam nossa pedagogia"
        subtitle="Cada decisão pedagógica nasce destes princípios — eles guiam o cotidiano da escola e o cuidado com cada criança."
      />

      <div class="pilares-grid">
        {features.map((feature, i) => (
          <FeatureCard
            title={feature.title}
            description={feature.description}
            icon={feature.icon}
            link={feature.link}
            delay={i * 80}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. NOSSOS AMBIENTES
       ============================================================ -->
  <section id="ambientes" class="section">
    <div class="container">
      <SectionTitle
        tag="Ambientes Projetados para a Infância"
        title="Espaços que estimulam a curiosidade e a segurança"
        subtitle="Cada ambiente é pensado em escala infantil, com atenção a higiene, conforto, acessibilidade e a estímulos para o desenvolvimento integral."
      />

      <div class="ambientes-grid">
        {ambientes.map((ambiente, i) => (
          <article class="ambiente-card reveal" data-reveal-delay={i * 70}>
            <div class="ambiente-shell" aria-hidden="true">
              <div class="ambiente-core">
                <img
                  src={ambiente.image}
                  alt={`Ambiente: ${ambiente.name} — ${ambiente.description}`}
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="300"
                />
                <div class="ambiente-caption">
                  <h3>{ambiente.name}</h3>
                  <p>{ambiente.description}</p>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. GALERIA
       ============================================================ -->
  <section id="galeria" class="section section-muted">
    <div class="container">
      <SectionTitle
        tag="Galeria"
        title="O cotidiano em imagens"
        subtitle="Um recorte do dia a dia das nossas turmas — do berçário ao infantil II."
      />

      <Gallery images={galleryImages} id="home-gallery" />
    </div>
  </section>

  <!-- ============================================================
       6. DEPOIMENTOS
       ============================================================ -->
  <section id="depoimentos" class="section">
    <div class="container">
      <SectionTitle
        tag="Famílias Villa Prime"
        title="Quem vive a escola, conta"
        subtitle="A confiança das famílias é a maior credencial que carregamos. Conheça algumas histórias."
      />

      <div class="depoimentos-grid">
        {testimonials.map((t, i) => (
          <TestimonialCard
            quote={t.quote}
            name={t.name}
            role={t.role}
            avatar={t.avatar}
            rating={t.rating}
            delay={i * 100}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. FAQ PREVIEW
       ============================================================ -->
  <section id="faq" class="section section-muted">
    <div class="container">
      <SectionTitle
        tag="Perguntas Frequentes"
        title="Esclareça as suas dúvidas"
        subtitle="Reunimos as cinco perguntas que mais ouvimos das famílias durante a visita. Não encontrou a sua?"
      />

      <FAQ items={faqPreview} schema={true} />

      <div class="faq-cta reveal" data-reveal-delay="200">
        <CTAButton
          text="Tire todas as suas dúvidas — Fale conosco"
          href="/contato/"
          variant="secondary"
          size="md"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. CTA FINAL
       ============================================================ -->
  <section id="visita" class="section-lg cta-final">
    <div class="cta-final-glow" aria-hidden="true"></div>
    <div class="cta-final-noise" aria-hidden="true"></div>

    <div class="container cta-final-content reveal">
      <span class="eyebrow eyebrow-light">Próximo Passo</span>
      <h2 class="cta-final-title">
        Venha conhecer o Villa Prime
      </h2>
      <p class="cta-final-subtitle">
        Agende uma visita guiada e descubra por que tantas famílias escolhem a
        nossa escola para os primeiros anos das suas crianças.
      </p>

      <div class="cta-final-actions">
        <CTAButton
          text="Conversar pelo WhatsApp"
          href={whatsappLink()}
          variant="whatsapp"
          size="lg"
        />
        <CTAButton
          text={`Ligar: ${schoolInfo.phone}`}
          href={`tel:${schoolInfo.phoneRaw}`}
          variant="outline"
          size="lg"
        />
      </div>

      <p class="cta-final-hours">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
        </svg>
        <span>{schoolInfo.hours}</span>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Shared utilities
     ============================================================ */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-700);
    background-color: var(--color-accent-50);
    border: 1px solid var(--color-accent-200);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .eyebrow-light {
    color: var(--color-accent-200);
    background-color: rgb(255 255 255 / 0.06);
    border-color: rgb(255 255 255 / 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .section-muted {
    background-color: var(--color-surface-muted);
  }

  /* ============================================================
     2. SOBRE A ESCOLA — split layout
     ============================================================ */
  .section-sobre {
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .sobre-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  @media (max-width: 1024px) {
    .sobre-grid {
      grid-template-columns: 1fr;
    }
  }

  .sobre-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .sobre-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw + 1rem, 3rem);
    line-height: 1.15;
    color: var(--color-primary-800);
    margin: 0;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .sobre-lead {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.6vw + 0.85rem, 1.2rem);
    line-height: 1.65;
    color: var(--color-neutral-700);
    margin: 0;
  }

  .sobre-body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-neutral-600);
    margin: 0;
  }

  /* Pillars row inside Sobre */
  .sobre-pillars {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
    padding-block: var(--space-2);
    margin-block: var(--space-2);
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  @media (max-width: 640px) {
    .sobre-pillars {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }

  .sobre-pillar {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-block: var(--space-3);
  }

  .sobre-pillar-num {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-accent-600);
    line-height: 1;
  }

  .sobre-pillar-label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    line-height: 1.4;
  }

  .sobre-cta {
    display: flex;
    margin-top: var(--space-2);
  }

  /* Sobre image — double-bezel frame */
  .sobre-image {
    position: relative;
    align-self: stretch;
  }

  .sobre-image-shell {
    display: block;
    padding: 8px;
    background: linear-gradient(
      135deg,
      rgb(0 66 84 / 0.06) 0%,
      rgb(212 169 16 / 0.10) 100%
    );
    border: 1px solid var(--color-neutral-200);
    border-radius: calc(var(--radius-2xl) + 8px);
    box-shadow: var(--shadow-xl);
  }

  .sobre-image-core {
    overflow: hidden;
    border-radius: var(--radius-2xl);
    aspect-ratio: 4 / 5;
    background-color: var(--color-primary-100);
    box-shadow: inset 0 1px 1px rgb(255 255 255 / 0.4);
  }

  .sobre-image-core img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Floating accent badge */
  .sobre-image-badge {
    position: absolute;
    bottom: -1.25rem;
    left: -1.25rem;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-surface);
    color: var(--color-primary-800);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--color-neutral-200);
    max-width: 12rem;
  }

  .sobre-image-badge svg {
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    color: var(--color-accent-500);
  }

  .sobre-image-badge span {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.2;
  }

  /* ============================================================
     3. PILARES — 2x2 grid
     ============================================================ */
  .pilares-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 768px) {
    .pilares-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================================
     4. AMBIENTES — 3-col / 2-col / 1-col grid
     ============================================================ */
  .ambientes-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  @media (max-width: 1024px) {
    .ambientes-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .ambientes-grid {
      grid-template-columns: 1fr;
    }
  }

  .ambiente-card {
    margin: 0;
  }

  /* Double-bezel frame */
  .ambiente-shell {
    display: block;
    padding: 6px;
    background: linear-gradient(
      135deg,
      rgb(0 66 84 / 0.04) 0%,
      rgb(212 169 16 / 0.08) 100%
    );
    border: 1px solid var(--color-neutral-200);
    border-radius: calc(var(--radius-xl) + 6px);
    box-shadow: var(--shadow-sm);
    transition:
      transform 350ms cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 350ms cubic-bezier(0.32, 0.72, 0, 1),
      border-color 350ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .ambiente-card:hover .ambiente-shell {
    transform: translateY(-3px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-primary-200);
  }

  .ambiente-core {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--color-primary-100);
  }

  .ambiente-core img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: transform;
  }

  .ambiente-card:hover .ambiente-core img {
    transform: scale(1.04);
  }

  /* Glass-dark caption pinned to the bottom */
  .ambiente-caption {
    position: absolute;
    inset: auto 0 0 0;
    padding: var(--space-4) var(--space-5);
    background: linear-gradient(
      180deg,
      rgb(0 30 43 / 0) 0%,
      rgb(0 30 43 / 0.7) 60%,
      rgb(0 30 43 / 0.92) 100%
    );
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #fff;
  }

  .ambiente-caption h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.25rem;
    line-height: 1.2;
  }

  .ambiente-caption p {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgb(255 255 255 / 0.85);
    margin: 0;
    line-height: 1.4;
  }

  /* ============================================================
     6. DEPOIMENTOS — 3-col / 1-col stack
     ============================================================ */
  .depoimentos-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .depoimentos-grid {
      grid-template-columns: 1fr;
      max-width: 36rem;
      margin-inline: auto;
    }
  }

  /* ============================================================
     7. FAQ CTA
     ============================================================ */
  .faq-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-10);
  }

  /* ============================================================
     8. CTA FINAL — gradient warm fullwidth
     ============================================================ */
  .cta-final {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    background: linear-gradient(
      135deg,
      var(--color-primary-900) 0%,
      var(--color-primary-700) 55%,
      var(--color-accent-700) 100%
    );
    padding-block: clamp(5rem, 12vh, 8rem);
  }

  .cta-final-glow {
    position: absolute;
    top: -20%;
    right: -15%;
    width: 70%;
    height: 100%;
    background: radial-gradient(
      ellipse at center,
      rgb(246 201 31 / 0.18) 0%,
      transparent 60%
    );
    pointer-events: none;
    z-index: -1;
  }

  .cta-final-noise {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    mix-blend-mode: overlay;
  }

  .cta-final-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    text-align: center;
    max-width: 56rem;
  }

  .cta-final-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 1rem, 3.75rem);
    line-height: 1.1;
    color: #fff;
    margin: 0;
    letter-spacing: -0.02em;
    text-wrap: balance;
    text-shadow: 0 2px 24px rgb(0 0 0 / 0.25);
  }

  .cta-final-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.8vw + 0.75rem, 1.25rem);
    line-height: 1.6;
    color: rgb(255 255 255 / 0.9);
    max-width: 44rem;
    margin: 0;
    text-wrap: pretty;
  }

  .cta-final-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .cta-final-hours {
