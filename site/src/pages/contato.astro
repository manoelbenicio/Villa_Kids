---
/**
 * @file contato.astro
 * @description Página /contato/ — formulário + painel de informações com
 *              endereço, telefone, e-mail, horário, redes sociais e mapa
 *              embutido. WhatsApp como alternativa rápida.
 *
 * @author GEMINI-UX
 * @phase 5
 * @created 2026-05-17T21:45:00Z
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import CTAButton from '../components/CTAButton.astro';
import { schoolInfo, whatsappLink } from '../data/school-info.ts';

// Google Maps embed URL — uses the address text. Replace with the
// real place_id when the school's Google Business Profile is set up.
const mapsQuery = encodeURIComponent(
  `${schoolInfo.address.fullStreet} ${schoolInfo.address.zip}`,
);
const mapsEmbedUrl = `https://www.google.com/maps?q=${mapsQuery}&output=embed`;
const mapsLinkUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<BaseLayout
  title="Fale Conosco — Contato"
  description="Entre em contato com o Colégio Villa Prime. Endereço, telefone, e-mail, horário de funcionamento e formulário direto. Atendimento humano em até 1 hora útil."
  schemaType="WebPage"
>
  <PageHero
    eyebrow="Estamos por perto"
    title="Fale Conosco"
    subtitle="Tire dúvidas, agende uma visita ou inicie o processo de matrícula. Respondemos em até 1 hora útil, com atendimento humano."
    breadcrumbs={[
      { label: 'Início', href: '/' },
      { label: 'Contato' },
    ]}
    backgroundImage="/images/sobre/sobre-main.svg"
  />

  <!-- ============================================================
       Quick WhatsApp CTA (sticky alternative)
       ============================================================ -->
  <section class="quick-strip" data-animate>
    <div class="container quick-strip-inner reveal" data-animate>
      <div class="quick-strip-text">
        <span class="quick-strip-eyebrow">
          <span class="quick-strip-eyebrow-dot" aria-hidden="true"></span>
          Atendimento Rápido
        </span>
        <p>Quer falar agora? Use o WhatsApp e converse direto com a coordenação.</p>
      </div>
      <CTAButton
        text="Conversar pelo WhatsApp"
        href={whatsappLink('Olá! Cheguei pelo site e gostaria de falar com vocês.')}
        variant="whatsapp"
        size="lg"
      />
    </div>
  </section>

  <!-- ============================================================
       Layout 2-col: Form + Info
       ============================================================ -->
  <section class="section container" data-animate>
    <div class="contato-grid stagger" data-animate>
      <!-- Form -->
      <div class="contato-form-side reveal" data-animate>
        <header class="contato-form-header">
          <span class="eyebrow">
            <span class="eyebrow-dot" aria-hidden="true"></span>
            Formulário
          </span>
          <h2 class="contato-heading">Envie sua mensagem</h2>
          <p class="contato-lead">
            Preencha o formulário abaixo e nossa equipe entrará em contato pelo
            canal de sua preferência.
          </p>
        </header>

        <ContactForm id="form-contato" />
      </div>

      <!-- Info panel -->
      <aside class="contato-info-side reveal" data-reveal-delay="120" data-animate>
        <header class="contato-info-header">
          <span class="eyebrow">
            <span class="eyebrow-dot" aria-hidden="true"></span>
            Informações
          </span>
          <h2 class="contato-heading">Como nos encontrar</h2>
        </header>

        <ul class="info-list stagger" data-animate>
          <li class="info-item reveal" data-animate>
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 7-8 12-8 12s-8-5-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div class="info-text">
              <span class="info-label">Endereço</span>
              <a href={mapsLinkUrl} target="_blank" rel="noopener noreferrer">
                {schoolInfo.address.fullStreet}<br/>
                CEP {schoolInfo.address.zip}
              </a>
            </div>
          </li>

          <li class="info-item reveal" data-reveal-delay="80" data-animate>
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
            </span>
            <div class="info-text">
              <span class="info-label">Telefone</span>
              <a href={`tel:${schoolInfo.phoneRaw}`}>{schoolInfo.phone}</a>
            </div>
          </li>

          <li class="info-item reveal" data-reveal-delay="160" data-animate>
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
            </span>
            <div class="info-text">
              <span class="info-label">E-mail</span>
              <a href={`mailto:${schoolInfo.email}`}>{schoolInfo.email}</a>
            </div>
          </li>

          <li class="info-item reveal" data-reveal-delay="240" data-animate>
            <span class="info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <div class="info-text">
              <span class="info-label">Horário de funcionamento</span>
              <span>{schoolInfo.hours}</span>
            </div>
          </li>
        </ul>

        <!-- Social -->
        <div class="info-social">
          <span class="info-social-label">Acompanhe nas redes</span>
          <ul>
            {schoolInfo.social.instagram && (
              <li>
                <a
                  href={schoolInfo.social.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Instagram do Colégio Villa Prime"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z"/>
                    <path d="M17.5 6.5h.01"/>
                  </svg>
                  <span>{schoolInfo.social.instagramHandle}</span>
                </a>
              </li>
            )}
            {schoolInfo.social.facebook && (
              <li>
                <a
                  href={schoolInfo.social.facebook}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Facebook do Colégio Villa Prime"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3Z"/>
                  </svg>
                  <span>Facebook</span>
                </a>
              </li>
            )}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- ============================================================
       Mapa
       ============================================================ -->
  <section class="map-section" data-animate>
    <div class="container">
      <header class="map-header reveal" data-animate>
        <span class="eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Localização
        </span>
        <h2 class="contato-heading">Onde estamos</h2>
        <p class="contato-lead">
          Visitas guiadas com agendamento prévio. Estacionamento local e acesso facilitado.
        </p>
      </header>

      <div class="map-shell reveal" data-reveal-delay="120" data-animate>
        <div class="map-core">
          <iframe
            src={mapsEmbedUrl}
            title={`Localização do ${schoolInfo.name} no Google Maps`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
        <a class="map-link" href={mapsLinkUrl} target="_blank" rel="noopener noreferrer">
          Abrir no Google Maps
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Shared utilities
     ============================================================ */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--vp-purple, #9B59B6);
    background-color: color-mix(in srgb, var(--vp-purple, #9B59B6) 10%, white);
    border: 1px solid color-mix(in srgb, var(--vp-purple, #9B59B6) 24%, white);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--vp-purple, #9B59B6);
  }

  .contato-heading {
    font-size: clamp(1.75rem, 2.4vw + 0.8rem, 2.5rem);
    line-height: 1.15;
    color: var(--vp-purple-deep, #6C3483);
    margin: var(--space-2) 0 var(--space-2);
    letter-spacing: -0.015em;
  }

  .contato-lead {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--color-neutral-600);
    margin: 0;
    max-width: 36rem;
  }

  /* ============================================================
     Quick WhatsApp strip
     ============================================================ */
  .quick-strip {
    background-color: var(--vp-gray-50, #F9FAFB);
    border-top: 1px solid var(--color-neutral-100);
    border-bottom: 1px solid var(--color-neutral-100);
    padding-block: var(--space-6);
  }

  .quick-strip-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .quick-strip-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .quick-strip-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.3rem 0.85rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--vp-purple, #9B59B6);
    background-color: color-mix(in srgb, var(--vp-purple, #9B59B6) 10%, white);
    border: 1px solid color-mix(in srgb, var(--vp-purple, #9B59B6) 24%, white);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .quick-strip-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--vp-purple, #9B59B6);
    box-shadow: 0 0 8px rgb(155 89 182 / 0.45);
  }

  .quick-strip-text p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--vp-purple-deep, #6C3483);
    font-weight: 500;
  }

  /* ============================================================
     Contato grid (form + info)
     ============================================================ */
  .contato-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2.5rem, 4vw, 4rem);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .contato-grid { grid-template-columns: 1fr; }
  }

  .contato-form-side,
  .contato-info-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contato-form-header,
  .contato-info-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* ContactForm reset (no extra padding/box on this page) */
  .contato-form-side :global(.contact-form) {
    padding: var(--space-6);
    background-color: var(--color-surface);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
  }

  /* ============================================================
     Info list
     ============================================================ */
  .info-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .info-item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .info-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--vp-gold-deep, #DAA520);
    background: linear-gradient(135deg, color-mix(in srgb, var(--vp-gold, #FFD700) 12%, white) 0%, color-mix(in srgb, var(--vp-gold, #FFD700) 25%, white) 100%);
    border: 1px solid color-mix(in srgb, var(--vp-gold, #FFD700) 45%, white);
    border-radius: var(--radius-md);
    margin-top: 2px;
  }

  .info-icon svg { width: 18px; height: 18px; }

  .info-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1.45;
  }

  .info-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-neutral-500);
  }

  .info-text a,
  .info-text span {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--vp-purple-deep, #6C3483);
    text-decoration: none;
    transition: color 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .info-text a:hover { color: var(--vp-purple, #9B59B6); }

  /* Social */
  .info-social {
    margin-top: var(--space-2);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-neutral-100);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .info-social-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-neutral-500);
  }

  .info-social ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .info-social a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.5rem 0.9rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--vp-purple-deep, #6C3483);
    background-color: var(--color-surface);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition:
      transform 200ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .info-social a:hover {
    transform: translateY(-1px);
    border-color: var(--vp-gold, #FFD700);
    color: var(--vp-gold-deep, #DAA520);
  }

  .info-social svg { width: 16px; height: 16px; color: var(--vp-gold-deep, #DAA520); }

  /* ============================================================
     Map section
     ============================================================ */
  .map-section {
    background-color: var(--vp-gray-50, #F9FAFB);
    padding-block: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--color-neutral-100);
  }

  .map-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  /* Double-bezel frame for the map iframe */
  .map-shell {
    position: relative;
    padding: 8px;
    background: linear-gradient(135deg, rgb(155 89 182 / 0.05) 0%, rgb(218 165 32 / 0.10) 100%);
    border: 1px solid var(--color-neutral-200);
    border-radius: calc(var(--radius-xl) + 8px);
    box-shadow: var(--shadow-xl);
  }

  .map-core {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    aspect-ratio: 16 / 9;
    background-color: color-mix(in srgb, var(--vp-purple, #9B59B6) 14%, white);
  }

  @media (max-width: 768px) {
    .map-core { aspect-ratio: 4 / 3; }
  }

  .map-core iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .map-link {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.65rem 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--vp-purple-deep, #6C3483);
    background-color: rgb(255 255 255 / 0.96);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-lg);
    text-decoration: none;
    transition:
      transform 200ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .map-link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
    color: var(--vp-purple, #9B59B6);
  }

  .map-link svg { width: 14px; height: 14px; }

  @media (prefers-reduced-motion: reduce) {
    .info-social a,
    .map-link { transition: none; }
    .info-social a:hover,
    .map-link:hover { transform: none; }
  }
</style>
