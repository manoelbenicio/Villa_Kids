---
/**
 * @file tecnologia.astro
 * @description Página /tecnologia/ — apresenta os recursos tecnológicos
 *              da escola (agenda digital, monitoramento, plataforma de
 *              comunicação com famílias, recursos pedagógicos digitais).
 *
 * @author GEMINI-UX
 * @phase 4
 * @created 2026-05-17T21:34:00Z
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CTAButton from '../components/CTAButton.astro';
import ContactMiniSection from '../components/ContactMiniSection.astro';
import { whatsappLink } from '../data/school-info.ts';

// --- Recursos tecnológicos principais ---
const techFeatures = [
  {
    title: 'Agenda Digital',
    description:
      'App exclusivo onde os pais acompanham em tempo real a rotina, alimentação, soneca, atividades e fotos do dia da criança.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
  },
  {
    title: 'Câmeras de Monitoramento',
    description:
      'Sistema de CCTV com cobertura integral dos ambientes coletivos, garantindo segurança 24 horas por dia.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="m22 7-7 5 7 5V7Z"/></svg>`,
  },
  {
    title: 'Controle de Acesso por Biometria',
    description:
      'Entrada e saída controladas por biometria com registro auditável — só pessoas autorizadas têm acesso à escola.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><path d="M12 2a10 10 0 0 1 7.43 16.61"/></svg>`,
  },
  {
    title: 'Plataforma de Comunicação',
    description:
      'Canal direto com a coordenação pedagógica, agenda de reuniões e biblioteca de materiais para os pais.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/></svg>`,
  },
  {
    title: 'Lousa Interativa',
    description:
      'Recursos audiovisuais e lousas interativas integrados aos projetos pedagógicos, ampliando o repertório das crianças.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  },
  {
    title: 'Backup em Nuvem',
    description:
      'Memórias do desenvolvimento da criança preservadas com segurança em nuvem — relatórios, fotos e marcos disponíveis para as famílias.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19a4.5 4.5 0 1 0-1.16-8.85A6 6 0 0 0 5 12.5"/><path d="M5 19h12.5"/><path d="M8 19v-7"/><path d="m5 16 3-4 3 4"/></svg>`,
  },
];

// --- Diferenciais explicativos ---
const techDifferentials = [
  {
    title: 'Tecnologia a serviço da pedagogia',
    detail:
      'A tecnologia, no Villa Prime, é sempre um meio — nunca o fim. Cada recurso digital é introduzido com intencionalidade pedagógica e mediação adulta.',
  },
  {
    title: 'Tempo de tela equilibrado',
    detail:
      'Respeitamos as recomendações da Sociedade Brasileira de Pediatria sobre exposição às telas, especialmente nos primeiros anos.',
  },
  {
    title: 'LGPD e privacidade',
    detail:
      'Os dados das famílias e das crianças são tratados com critérios rigorosos de segurança da informação e em conformidade com a LGPD.',
  },
];
---

<BaseLayout
  title="Tecnologia e Inovação"
  description="Agenda digital, câmeras, biometria, lousa interativa e comunicação com famílias a serviço da rotina pedagógica."
  schemaType="WebPage"
>
  <PageHero
    eyebrow="Tecnologia & Inovação"
    title="Tecnologia que aproxima famílias e escola"
    subtitle="Plataformas digitais que dão transparência ao cotidiano e recursos audiovisuais que ampliam o aprendizado — sempre a serviço da pedagogia."
    breadcrumbs={[
      { label: 'Início', href: '/' },
      { label: 'Tecnologia' },
    ]}
    backgroundImage="/images/ambientes/multimidia.svg"
  />

  <!-- ============================================================
       1. Recursos tecnológicos
       ============================================================ -->
  <section class="section container" data-animate>
    <SectionTitle
      tag="Recursos"
      title="Tecnologia integrada à rotina escolar"
      subtitle="Seis frentes em que a tecnologia apoia o cuidado, a comunicação e a aprendizagem na primeira infância."
    />

    <div class="tech-grid stagger" data-animate>
      {techFeatures.map((item, i) => (
        <FeatureCard
          title={item.title}
          description={item.description}
          icon={item.icon}
          delay={i * 70}
        />
      ))}
    </div>
  </section>

  <!-- ============================================================
       2. Diferenciais
       ============================================================ -->
  <section class="section section-alt" data-animate>
    <div class="container">
      <SectionTitle
        tag="Princípios"
        title="Como pensamos a tecnologia para a infância"
        subtitle="A tecnologia é um meio. O que importa é a forma como ela apoia o desenvolvimento integral das crianças."
      />

      <div class="differentials-grid stagger" data-animate>
        {techDifferentials.map((diff, i) => (
          <article class="differential reveal" data-reveal-delay={i * 80} data-animate>
            <span class="differential-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="differential-title">{diff.title}</h3>
            <p class="differential-detail">{diff.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. CTA — Saiba mais sobre os diferenciais
       ============================================================ -->
  <section class="cta-banner section-dark" data-animate>
    <div class="cta-banner-glow" aria-hidden="true"></div>
    <div class="container cta-banner-inner reveal" data-animate>
      <span class="cta-banner-eyebrow">
        <span class="cta-banner-eyebrow-dot" aria-hidden="true"></span>
        Diferenciais
      </span>
      <h2 class="cta-banner-title">Saiba mais sobre nossos diferenciais</h2>
      <p class="cta-banner-subtitle">
        Em uma visita guiada, mostramos como a tecnologia se integra ao
        cotidiano sem substituir o que importa: o olhar, a escuta e o vínculo.
      </p>
      <div class="cta-banner-actions">
        <CTAButton
          text="Agendar uma visita"
          href={whatsappLink('Olá! Gostaria de conhecer melhor os recursos tecnológicos do Villa Prime.')}
          variant="whatsapp"
          size="lg"
        />
        <CTAButton text="Ver Segurança" href="/seguranca/" variant="outline" size="lg" />
      </div>
    </div>
  </section>

  <ContactMiniSection
    title="Curioso sobre nossa plataforma para pais?"
    subtitle="Mostramos uma demo do app e da agenda digital em uma conversa de 10 minutos."
  />
</BaseLayout>

<style>
  .section-alt {
    background-color: var(--vp-gray-50, #F9FAFB);
  }

  /* ============================================================
     Recursos tecnológicos — 3 col / 2 col / 1 col
     ============================================================ */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  @media (max-width: 1024px) {
    .tech-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .tech-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================================
     Differentials — numbered cards
     ============================================================ */
  .differentials-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .differentials-grid {
      grid-template-columns: 1fr;
    }
  }

  .differential {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-5) var(--space-5);
    background-color: var(--color-surface);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    transition:
      transform 300ms cubic-bezier(0.32, 0.72, 0, 1),
      box-shadow 300ms cubic-bezier(0.32, 0.72, 0, 1),
      border-color 300ms cubic-bezier(0.32, 0.72, 0, 1);
    overflow: hidden;
  }

  .differential:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-xl);
    border-color: var(--vp-purple-light, #D2B4DE);
  }

  .differential-num {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    color: color-mix(in srgb, var(--vp-gold, #FFD700) 25%, white);
    user-select: none;
    -webkit-text-stroke: 1px color-mix(in srgb, var(--vp-gold, #FFD700) 70%, white);
  }

  .differential-title {
    font-size: var(--text-xl);
    color: var(--vp-purple-deep, #6C3483);
    margin: 0;
    line-height: 1.25;
  }

  .differential-detail {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--color-neutral-700);
    margin: 0;
  }

  /* ============================================================
     CTA banner (shared)
     ============================================================ */
  .cta-banner {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    background: var(--grad-hero, linear-gradient(135deg, #6C3483 0%, #9B59B6 40%, #BB8FCE 100%));
    padding-block: clamp(4rem, 9vh, 6rem);
  }

  .cta-banner-glow {
    position: absolute;
    top: -25%;
    right: -15%;
    width: 70%;
    height: 100%;
    background: radial-gradient(ellipse at center, rgb(155 89 182 / 0.18) 0%, transparent 60%);
    pointer-events: none;
    z-index: -1;
  }

  .cta-banner-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    text-align: center;
    max-width: 52rem;
  }

  .cta-banner-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--vp-purple-light, #D2B4DE);
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(210 180 222 / 0.28);
    border-radius: var(--radius-full);
  }

  .cta-banner-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--vp-purple-light, #D2B4DE);
  }

  .cta-banner-title {
    font-size: clamp(1.75rem, 3vw + 1rem, 2.75rem);
    line-height: 1.15;
    color: #fff;
    margin: 0;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .cta-banner-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.6vw + 0.85rem, 1.15rem);
    line-height: 1.6;
    color: rgb(255 255 255 / 0.88);
    margin: 0;
    max-width: 40rem;
    text-wrap: pretty;
  }

  .cta-banner-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  @media (prefers-reduced-motion: reduce) {
    .differential { transition: none; }
    .differential:hover { transform: none; }
  }
</style>
