---
/**
 * @file BaseLayout.astro
 * @description Master layout wrapping every page. Wires up:
 *              - <SEOHead /> (meta + OG + Twitter)
 *              - <SchemaOrg /> (JSON-LD)
 *              - Google Fonts preconnect + Inter + Playfair Display
 *              - global.css design tokens
 *              - Header + main slot + Footer
 *              - WhatsApp floating button on every page
 *              - scroll-reveal client script
 *
 * @author GEMINI-UX
 * @phase 2
 * @created 2026-05-17T20:49:00Z
 */
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

export interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  /** Schema type override (default: site-wide LocalBusiness/EducationalOrg). */
  schemaType?: 'LocalBusiness' | 'EducationalOrganization' | 'WebPage' | 'Default';
  /** Class added to <body> for page-specific styling hooks. */
  bodyClass?: string;
}

const {
  title,
  description,
  canonicalURL,
  ogImage,
  ogType,
  noindex,
  schemaType = 'Default',
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />

    <!-- Google Fonts: async load to avoid render-blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap&subset=latin,latin-ext"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap&subset=latin,latin-ext" /></noscript>

    <!-- Preload hero image for LCP -->
    <link rel="preload" as="image" href="/images/hero/hero-main.svg" />

    <!-- hreflang for geo-targeting -->
    <link rel="alternate" hreflang="pt-BR" href={new URL(Astro.url.pathname, Astro.site ?? 'https://www.colegiovillaprime.com.br').toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname, Astro.site ?? 'https://www.colegiovillaprime.com.br').toString()} />

    <SchemaOrg
      type={schemaType}
      name={title}
      description={description}
      url={canonicalURL}
    />
  </head>

  <body class={bodyClass}>
    <Header />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />

    <WhatsAppButton />

    <!-- Client-side enhancements (scroll-reveal + countup) -->
    <script>
      import '../scripts/scroll-reveal.ts';
    </script>
  </body>
</html>
